{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "sourceMap": true,
        "noImplicitAny": true,
        "esModuleInterop": false,
        "downlevelIteration": true,
        "isolatedModules": true,
        "strict": true,
        "jsx": "react",
        "baseUrl": ".",
        "paths": {
            "@ankoh/dashql-protobuf": [
                "./bazel-bin/packages/dashql-protobuf/dist"
            ],
            "@ankoh/dashql-protobuf/*": [
                "./bazel-bin/packages/dashql-protobuf/dist/*"
            ]
        },
        "types": [
            "node",
            "jest"
        ],
        "lib": [
            "es6",
            "es2020",
            "dom"
        ],
        "allowJs": true,
        "plugins": [
            {
                "name": "typescript-plugin-css-modules"
            }
        ]
    },
    "include": [
        "packages/dashql-app/src/**/*",
        "packages/dashql-app/test/**/*.ts",
        "packages/dashql-app/*.ts",
        "packages/dashql-app/bundles/*.ts",
        "packages/dashql-app/types/*.d.ts",
        "bazel-bin/packages/dashql-protobuf/dist/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
