{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "sourceMap": true,
        "noImplicitAny": true,
        "esModuleInterop": false,
        "downlevelIteration": true,
        "isolatedModules": true,
        "strict": true,
        "jsx": "react",
        "baseUrl": ".",
        "paths": {
            "@ankoh/dashql-flatbuf": [
                "./bazel-bin/packages/dashql-app/dependencies/dashql-flatbuf"
            ],
            "@ankoh/dashql-flatbuf/*": [
                "./bazel-bin/packages/dashql-app/dependencies/dashql-flatbuf/*"
            ],
            "@ankoh/dashql-protobuf": [
                "./bazel-bin/packages/dashql-app/dependencies/dashql-protobuf"
            ],
            "@ankoh/dashql-protobuf/*": [
                "./bazel-bin/packages/dashql-app/dependencies/dashql-protobuf/*"
            ],
            "@ankoh/dashql-corek": [
                "./packages/dashql-core/api"
            ],
            "@ankoh/dashql-core/*": [
                "./packages/dashql-core/api/*"
            ],
            "@ankoh/dashql-compute": [
                "./bazel-bin/packages/dashql-compute/dist_gen_pkg/dashql_compute.js"
            ],
            "@ankoh/dashql-compute/*": [
                "./bazel-bin/packages/dashql-compute/dist_gen_pkg/*"
            ],
            "@ankoh/dashql-svg-symbols": [
                "./bazel-bin/packages/svg-symbols/symbols.generated.svg"
            ]
        },
        "types": [
            "node",
            "jest"
        ],
        "lib": [
            "es6",
            "es2020",
            "dom"
        ],
        "allowJs": true,
        "plugins": [
            {
                "name": "typescript-plugin-css-modules"
            }
        ]
    },
    "include": [
        "packages/dashql-app/src/**/*",
        "packages/dashql-app/test/**/*.ts",
        "packages/dashql-app/*.ts",
        "packages/dashql-app/bundles/*.ts",
        "packages/dashql-app/types/*.d.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
