{
    "editor.formatOnSave": true,
    "editor.trimAutoWhitespace": true,
    "files.insertFinalNewline": true,
    "eslint.workingDirectories": ["./packages/app", "./packages/core", "./packages/benchmarks", "./packages/jmespath"],
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typscript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[dockerfile]": {
        "editor.formatOnSave": false
    },
    "[xml]": {
        "editor.formatOnSave": false
    },
    "files.watcherExclude": {
        "**/.cache": true,
        "**/.git": true,
        "**/.nyc_output": true,
        "**/dist": true,
        "**/node_modules": true,
        "**/target*": true,
        "**/.ccache": true,
        "**/.emscripten_cache": true,
        "**/lib/build": true,
        "**/submodules": true
    },
    "search.exclude": {
        "**/.cache": true,
        "**/.git": true,
        "**/.nyc_output": true,
        "**/dist": true,
        "**/node_modules": true,
        "**/target*": true,
        "**/.ccache": true,
        "**/.emscripten_cache": true,
        "**/lib/build": true
    },
    "jest.autoRun": "off",
    "testMate.cpp.test.executables": "./lib/build/Debug/tester",
    "testMate.cpp.test.workingDirectory": "./lib/",

    "launch": {
        "configurations": [
            {
                "type": "node",
                "request": "launch",
                "name": "Jest",
                "program": "${workspaceRoot}/node_modules/jest/bin/jest.js",
                "args": [],
                "skipFiles": ["node_modules"]
            }
        ]
    },
    "rust-analyzer.cargo.features": ["native", "wasm", "node"]
}
