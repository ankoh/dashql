{
    "name": "@dashql/duckdb",
    "version": "0.0.8",
    "description": "DuckDB powered by WebAssembly",
    "author": "Andre Kohn <kohn.a@outlook.com>",
    "license": "MIT",
    "dependencies": {
        "@dashql/proto": "file:../../proto/",
        "flatbuffers": "^1.12.0"
    },
    "devDependencies": {
        "@types/emscripten": "^1.39.4",
        "@types/flatbuffers": "^1.10.0",
        "@types/jest": "^26.0.14",
        "benny": "^3.6.14",
        "clean-webpack-plugin": "^3.0.0",
        "compression-webpack-plugin": "^7.0.0",
        "file-loader": "^6.1.0",
        "jest": "^26.4.2",
        "jest-junit": "^12.0.0",
        "kleur": "^4.1.3",
        "ts-jest": "^26.4.1",
        "ts-loader": "^8.0.4",
        "typescript": "^4.0.3",
        "webpack": "^5.1.3",
        "webpack-cli": "^4.1.0"
    },
    "scripts": {
        "build": "webpack --mode=production",
        "test": "node --experimental-wasm-threads --experimental-wasm-bulk-memory ./node_modules/jest/bin/jest.js",
        "test:ci": "node --experimental-wasm-threads --experimental-wasm-bulk-memory ./node_modules/jest/bin/jest.js --ci --reporters=default --reporters=jest-junit",
        "bench.iterator": "node --experimental-wasm-threads --experimental-wasm-bulk-memory benchmarks/iterator.mjs"
    },
    "files": [
        "dist/**/*.d.ts",
        "dist/**/*.js",
        "dist/*.wasm"
    ],
    "main": "./dist/targets/node/duckdb.js",
    "types": "./dist/targets/node/duckdb.d.ts",
    "browser": {
        "./dist/targets/node/duckdb.js": "./dist/targets/web/duckdb.js",
        "./dist/targets/node/duckdb_worker.js": "./dist/targets/web/duckdb_worker.js",
        "worker_threads": false,
        "perf_hooks": false,
        "fs": false,
        "buffer": false
    },
    "jest-junit": {
        "suiteName": "Javascript",
        "outputDirectory": "../../reports",
        "outputName": "tests_js.xml",
        "uniqueOutputName": "false",
        "classNameTemplate": "{classname}",
        "titleTemplate": "{title}",
        "ancestorSeparator": " › ",
        "usePathForSuiteName": "true"
    }
}
