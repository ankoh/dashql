include "query_plan.fbs";
include "sql_type.fbs";
include "vector.fbs";

namespace duckdb.web.proto;

// A query result chunk
table QueryResultChunk {
    query_id: uint64;
    row_count: uint64;
    columns: [Vector];
}

// A query result
table QueryResult {
    query_id: uint64;
    query_plan: QueryPlan;
    column_types: [SQLType];
    column_names: [string];
    data_chunks: [QueryResultChunk];
}
