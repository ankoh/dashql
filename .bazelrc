# dashql-core Bazel build uses Bzlmod (MODULE.bazel) and a module extension
# for flatbuffers, ankerl, rapidjson, and prebuilt Bison/M4/Flex (xPack).
# rules_cc and platforms come from BCR. No local bison/flex install required.
build --action_env=PATH

# Common pattern for 'opt'
build:release -c opt
build:release --strip=always

# Common pattern for 'debug'
build:debug -c dbg
