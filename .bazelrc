# Local overrides (gitignored, not committed).
try-import %workspace%/.bazelrc.user

# Isolated extension usages: separate crate_universe instances for compute (WASM) and native.
common --experimental_isolated_extension_usages
common --enable_platform_specific_config

# Align exec (proc-macro) and target compilation modes so that
# cfg(debug_assertions)-gated struct fields match in generated code.
# Tauri's generate_context!() can otherwise emit code that mismatches
# release targets when host/proc-macro compilation stays in fastbuild.
build --host_compilation_mode=fastbuild

# Use LLD on Linux.
# Otherwise Rust complains that it's incompatible with the gold linker
build:linux --host_linkopt=-fuse-ld=lld
build:linux --linkopt=-fuse-ld=lld

# macOS 13.3+ required for std::format (std::to_chars for long double).
# Set globally so all C/C++ deps (not just dashql_core) use the same target.
build --action_env=MACOSX_DEPLOYMENT_TARGET=13.3
build --host_action_env=MACOSX_DEPLOYMENT_TARGET=13.3
build --macos_minimum_os=13.3

# Suppress deprecation warnings in all external sources.  Protobuf's generated
# headers (virtual_includes) mark weak() [[deprecated]] but still call it
# internally; the warning fires in any TU (protobuf or abseil) that includes
# those headers, so the suppression must cover all external packages.
build --per_file_copt=external/.*@-Wno-deprecated-declarations
build --host_per_file_copt=external/.*@-Wno-deprecated-declarations

# Common pattern for fast validation.
build:fastbuild -c fastbuild
build:fastbuild --host_compilation_mode=fastbuild

# Full release mode for shipped artifacts only.
build:release -c opt
build:release --host_compilation_mode=opt
build:release --strip=always
build:release --copt=-O3
build:release --cxxopt=-O3
build:release --@rules_rust//rust/settings:extra_rustc_flag=-Copt-level=3
build:release --features=optimized_for_size
build:release --define=dashql_release=1

# Debug mode
build:debug -c dbg

# LLVM Source-Based Coverage (mirrors old llvm-profdata/llvm-cov pipeline).
# Requires clang as compiler (--repo_env=CC=clang on Linux; Xcode clang on macOS).
# --instrumentation_filter is supplied per-invocation to scope to first-party targets.
coverage --experimental_generate_llvm_lcov
coverage --combined_report=lcov

# Show errors by default
test --test_output=errors
# Show all tests with verbose test config
test:verbose --test_output=all
