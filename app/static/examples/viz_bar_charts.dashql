-- Fetch weather data
IMPORT csv_weather FROM 'https://static.dashql.com/data/examples/seattle-weather.csv';

-- Load data into DuckDB
LOAD weather FROM csv_weather USING CSV;

-- Visualize the weather data
VIZ weather USING STACKED BAR (
    x = (
        timeUnit = 'month',
        field = 'date',
        type = 'ordinal'
    ),
    y = (aggregate = 'count'),
    color = 'weather'
);
