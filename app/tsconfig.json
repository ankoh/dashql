{
      "compilerOptions": {
        "outDir": "./build/ts/",
        "target": "es6",
        "module": "es6",
        "moduleResolution": "node",
        "noImplicitAny": true,
        "types": ["node"],
        "jsx": "react",
        "plugins": [{ "name": "typescript-plugin-css-modules" }]
    },
    "exclude": [
        "./test/**/*.ts",
        "./node_modules"
    ],
    "include": [
        "./src/**/*"
    ]
}


