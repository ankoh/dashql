# FlatBuffers code generation for DashQL (C++ path via Bazel).
# TypeScript generation stays in scripts/generate_flatbuf.sh for now.
# Entry schema: dashql/index.fbs (includes all other .fbs).

load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

# All .fbs schemas (needed so flatc can resolve includes in the genrule).
FBS_DEPS = glob(["dashql/*.fbs"])

# Generate C++ from dashql/index.fbs using flatc. Flags match scripts/generate_flatbuf.sh.
# flatc --cpp produces only a .h (header-only; no .cc).
genrule(
    name = "dashql_buffers_cc_gen",
    srcs = FBS_DEPS,
    outs = ["dashql/buffers/index_generated.h"],
    cmd = """
        FLATC=$(location @com_google_flatbuffers//:flatc)
        INC=$$(dirname $$(dirname $(location dashql/index.fbs)))
        mkdir -p $(@D)
        $$FLATC -I $$INC -o $(@D) $$INC/dashql/index.fbs --cpp \\
            --gen-all \\
            --no-prefix --scoped-enums \\
            --reflect-types --reflect-names \\
            --gen-object-api --gen-name-strings --gen-compare \\
            --gen-mutable
    """,
    tools = ["@com_google_flatbuffers//:flatc"],
)

# Header-only cc_library so dashql-core can depend on it; include path is this package root
# so #include "dashql/buffers/index_generated.h" resolves.
cc_library(
    name = "dashql_buffers_cc",
    hdrs = [":dashql_buffers_cc_gen"],
    includes = ["."],
    deps = ["@com_google_flatbuffers//:flatbuffers"],
)
