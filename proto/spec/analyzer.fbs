include "action.fbs";
include "syntax/syntax.fbs";

namespace dashql.proto.analyzer;

enum ValueTypeID: uint8 {
    NONE = 0,
    BOOLEAN = 1,
    DOUBLE = 2,
    BIGINT = 3,
    DECIMAL = 4,
    VARCHAR = 5,
    DATE = 6,
    TIME = 7,
    TIMESTAMP = 8,
}

struct ValueType {
    type_id: ValueTypeID;
    width: uint16;
    scale: uint8;
}

table Value {
    type: ValueType;
    is_null: bool;
    data_u32: uint32;
    data_i64: int64;
    data_f64: double;
    data_str: string;
}

table NodeValue {
    node_id: uint32;
    value: Value;
}

table ParameterValue {
    statement_id: uint32;
    value: Value;
}

table ProgramInstantiation {
    parameters: [ParameterValue];
}

enum ErrorCode: uint8 {
    INVALID_INPUT
}

table Error {
    code: ErrorCode;
    location: syntax.Location;
    node: uint32;
    message: string;
}

table Plan {
    parameter_values: [ParameterValue];
    evaluated_nodes: [NodeValue];
    action_graph: action.ActionGraph;
    errors: [Error];
}
