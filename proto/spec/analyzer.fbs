include "action.fbs";
include "syntax.fbs";
include "syntax_dashql.fbs";
include "webdb/value.fbs";

namespace dashql.proto.analyzer;

table ParameterValue {
    statement: uint32;
    value: webdb.Value;
}

table ProgramParameters {
    values: [ParameterValue];
}

table Plan {
    program_evaluation: syntax.ProgramPatch;
    parameters: [ParameterValue];
    action_graph: action.ActionGraph;
}
