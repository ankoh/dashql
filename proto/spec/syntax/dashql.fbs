namespace dashql.proto.syntax;

enum ParameterType: uint8 {
    NONE = 0,
    INTEGER = 1,
    FLOAT = 2,
    TEXT = 3,
    DATE = 4,
    DATETIME = 5,
    TIME = 6,
    FILE = 7,
}

enum LoadMethodType: uint8 {
    NONE = 0,
    HTTP = 1,
    FILE = 2
}

enum ExtractMethodType: uint8 {
    NONE = 0,
    CSV = 1,
    JSON = 2
}

enum VizComponentTypeModifier: uint32 {
    NONE            = 0,
    STACKED         = 1,
    DEPENDENT       = 2,
    INDEPENDENT     = 4,
    POLAR           = 8,
    X               = 16,
    Y               = 32
}

enum VizComponentType: uint8 {
    NONE = 0,
    AREA,
    AXIS,
    BAR,
    BOX,
    CANDLESTICK,
    ERROR,
    HISTOGRAM,
    LINE,
    NUMBER,
    PIE,
    SCATTER,
    TABLE,
    TEXT,
    VORONOI,
}
