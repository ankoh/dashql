include "webdb/query_plan.fbs";
include "webdb/sql_type.fbs";
include "webdb/vector.fbs";

namespace dashql.proto.webdb;

table ImportDataChunk {
    table_id: uint64;
    row_count: uint64;
    columns: [Vector];
}

table ImportTable {
    table_id: uint64;
    table_name: string;
    column_types: [SQLType];
    column_names: [string];
}

table ImportHeader {
    tables: [ImportTable];
}
