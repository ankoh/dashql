include "syntax/syntax.fbs";
include "analyzer.fbs";
include "viz.fbs";

namespace dashql.proto.edit;

table VizChangePosition {
    statement_id: uint32;
    position: viz.Position;
}

union EditOperationVariant {
    VizChangePosition
}

table EditOperation {
    variant: EditOperationVariant;
}

table ProgramEdit {
    edits: [EditOperation];
}
