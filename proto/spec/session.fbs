include "action.fbs";
include "syntax.fbs";
include "syntax_dashql.fbs";

namespace dashql.proto.session;

table ParameterValue {
    type: syntax_dashql.ParameterType;
    origin_statement: uint32;
    value: string;
}

table ExtractCSV {
    action_id: uint32;
}

table Plan {
    program_evaluation: syntax.ProgramPatch;
    parameters: [ParameterValue];
    action_graph: action.ActionGraph;
}
