namespace dashql.proto.syntax;

struct Position { line: uint32; column: uint32; }
struct Location { begin: Position; end: Position; }

enum SectionTag: uint8 {
    NONE,
    I64Literal,
    F64Literal,
    StringLiteral,
    JSONPathExtract,
    CSVExtract,
    ParameterDeclaration,
    VizStatement,
    HTTPLoad,
    FileLoad,
}

struct SectionEntry {
    tag: SectionTag;
    index: uint32;
}

enum ParameterTag: uint8 {
    NONE = 0,
    INTEGER = 1,
    FLOAT = 2,
    TEXT = 3,
    DATE = 4,
    DATETIME = 5,
    TIME = 6,
    FILE = 7,
}

struct ParameterDeclaration {
    location: Location;
    tag: ParameterTag;
    name: SectionEntry;
    label: SectionEntry;
    default_value: SectionEntry;
}

struct QueryStatement {
    location: Location;
    name: SectionEntry;
    text: SectionEntry;
}

enum HTTPVerb: uint8 { NONE = 0, GET = 1, PUT = 2, POST = 3, }
struct HTTPLoad { location: Location; verb: HTTPVerb; url: SectionEntry; }
struct FileLoad { location: Location; }
struct LoadStatement { location: Location; name: SectionEntry; method: SectionEntry; }

struct JSONPathExtract { location: Location; }
struct CSVExtract { location: Location; }
struct ExtractStatement { location: Location; name: SectionEntry; data: SectionEntry; method: SectionEntry; }

enum VizTag: uint8 {
    NONE = 0,
    AREA = 1,
    BAR = 2,
    BOX = 3,
    BUBBLE = 4,
    GRID = 5,
    HISTOGRAM = 6,
    LINE = 7,
    NUMBER = 8,
    PIE = 9,
    POINT = 10,
    SCATTER = 11,
    TABLE = 12,
    TEXT = 13,
}
struct VizStatement {
    location: Location;
    tag: VizTag;
    name: SectionEntry;
    query_name: SectionEntry;
}

table Sections {
    literals_i64: [int64];
    literals_f64: [double];
    literals_string: [string];
    parameter_declarations: [ParameterDeclaration];
    loads_file: [FileLoad];
    loads_http: [HTTPLoad];
    extracts_csv: [CSVExtract];
    extracts_jsonpath: [JSONPathExtract];
    viz_statements: [VizStatement];
}

table Error {
    location: Location;
    message: string;
}

table Module {
    statements: [SectionEntry];
    sections: Sections;
    errors: [Error];
}
