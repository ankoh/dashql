{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dashql/auth.json",
  "definitions": {
    "AuthType": {
      "type": "string",
      "enum": ["AUTH_BASIC", "AUTH_OAUTH"],
      "description": "Auth type"
    },
    "BasicAuthParams": {
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "The username (for basic auth)"
        },
        "secret": {
          "type": "string",
          "description": "The secret (for basic auth, or access token for OAuth)"
        }
      },
      "required": ["username", "secret"],
      "additionalProperties": false
    },
    "TemporaryToken": {
      "type": "object",
      "properties": {
        "token": {
          "type": "string",
          "description": "The token"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time when this token was created"
        }
      },
      "required": ["token", "createdAt"],
      "additionalProperties": false
    },
    "OAuthFlowVariant": {
      "type": "string",
      "enum": ["UNSPECIFIED_FLOW", "WEB_OPENER_FLOW", "NATIVE_LINK_FLOW"],
      "description": "OAuth flow variant"
    },
    "OAuthPKCEChallenge": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string",
          "description": "The PKCE challenge"
        },
        "verifier": {
          "type": "string",
          "description": "The PKCE challenge verifier"
        }
      },
      "required": ["value", "verifier"],
      "additionalProperties": false
    },
    "OAuthParams": {
      "type": "object",
      "description": "Trino OAuth configuration",
      "properties": {
        "authorizationUrl": {
          "type": "string",
          "description": "The OAuth authorization url"
        },
        "tokenUrl": {
          "type": "string",
          "description": "The OAuth token url"
        },
        "clientId": {
          "type": "string",
          "description": "The OAuth client ID"
        },
        "callbackUrl": {
          "type": "string",
          "description": "The OAuth callback URL"
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "The OAuth scopes"
        }
      },
      "required": ["authorizationUrl", "tokenUrl", "clientId", "callbackUrl"],
      "additionalProperties": false
    },
    "SalesforceOAuthParams": {
      "type": "object",
      "properties": {
        "instanceUrl": {
          "type": "string",
          "description": "The url of the salesforce instance"
        },
        "appConsumerKey": {
          "type": "string",
          "description": "The consumer key of the connected app"
        },
        "requestedAt": {
          "type": "number",
          "description": "The request time in milliseconds since epoch"
        },
        "expiresAt": {
          "type": "number",
          "description": "The time when the authorization code expires"
        }
      },
      "required": ["instanceUrl", "appConsumerKey", "requestedAt", "expiresAt"],
      "additionalProperties": false
    },
    "TrinoAuthParams": {
      "type": "object",
      "description": "Trino auth parameters",
      "properties": {
        "authType": {
          "$ref": "#/definitions/AuthType",
          "description": "The auth type"
        },
        "basic": {
          "$ref": "#/definitions/BasicAuthParams",
          "description": "The params for the basic auth"
        },
        "oauth": {
          "$ref": "#/definitions/OAuthParams",
          "description": "The params for the oauth"
        }
      },
      "required": ["authType"],
      "additionalProperties": false
    },
    "OAuthState": {
      "type": "object",
      "properties": {
        "flowVariant": {
          "$ref": "#/definitions/OAuthFlowVariant",
          "description": "The OAuth flow variant"
        },
        "debugMode": {
          "type": "boolean",
          "description": "Is in debug mode? Our native dev server cannot override the deep-link handler. The oauth redirect will therefore not auto-open deep-links in debug mode."
        },
        "callbackUrl": {
          "type": "string",
          "description": "Optional callback URL for cross-origin relay. When set and on a different origin, dashql.app/oauth.html redirects the popup to this URL before posting the event, enabling BroadcastChannel delivery to dev servers."
        },
        "salesforceProvider": {
          "$ref": "#/definitions/SalesforceOAuthParams",
          "description": "The Salesforce OAuth provider"
        },
        "trinoProvider": {
          "$ref": "#/definitions/OAuthParams",
          "description": "The Trino OAuth provider"
        }
      },
      "required": ["flowVariant", "debugMode"],
      "additionalProperties": false
    },
    "OAuthRedirectData": {
      "type": "object",
      "properties": {
        "state": {
          "$ref": "#/definitions/OAuthState",
          "description": "The OAuth state"
        },
        "code": {
          "type": "string",
          "description": "The OAuth code"
        },
        "error": {
          "type": "string",
          "description": "The OAuth error (if any)"
        }
      },
      "required": ["state", "code"],
      "additionalProperties": false
    }
  }
}
