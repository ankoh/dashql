{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dashql/app_event.json",
  "title": "AppEventData",
  "type": "object",
  "oneOf": [
    {
      "properties": {
        "session": {
          "type": "string",
          "contentEncoding": "base64",
          "description": "Session ZIP (contains connection params, notebook scripts, etc.)"
        }
      },
      "required": ["session"],
      "additionalProperties": false
    },
    {
      "properties": {
        "oauthRedirect": {
          "$ref": "auth.json#/definitions/OAuthRedirectData",
          "description": "Provide the oauth redirect"
        }
      },
      "required": ["oauthRedirect"],
      "additionalProperties": false
    }
  ]
}
