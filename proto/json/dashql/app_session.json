{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dashql/app_session.json",
  "title": "SessionData",
  "description": "Session data structure (dashql-session.json) - includes connection params and notebook metadata",
  "type": "object",
  "properties": {
    "sessionId": {
      "type": "string",
      "description": "Unique session identifier (UUID v4). This is the authoritative identity; the storage location prefix is display-only."
    },
    "sessionPath": {
      "type": "string",
      "description": "Display-only path (e.g., \"opfs://sessions/<uuid>\" or \"fs://<dir>\"). Not authoritative and may be absent on newly written sessions; readers must tolerate its absence."
    },
    "storageType": {
      "type": "string",
      "enum": ["opfs", "native"],
      "description": "Where this session's files live. Defaults to \"opfs\" when omitted."
    },
    "nativePath": {
      "type": "string",
      "description": "Absolute directory holding this session's files when storageType is \"native\"."
    },
    "title": {
      "type": "string",
      "description": "The session title/name"
    },
    "connectionParams": {
      "$ref": "connection.json#/definitions/ConnectionParams",
      "description": "The connection params"
    },
    "notebook": {
      "$ref": "#/definitions/NotebookMetadata",
      "description": "The notebook metadata"
    },
    "lastModified": {
      "type": "string",
      "format": "date-time",
      "description": "When was last modified"
    },
    "lastAccessed": {
      "type": "string",
      "format": "date-time",
      "description": "When was last accessed"
    }
  },
  "required": ["sessionId", "title", "connectionParams", "notebook"],
  "additionalProperties": false,
  "definitions": {
    "NotebookOriginType": {
      "type": "string",
      "enum": ["FILE", "LOCAL", "HTTP"],
      "description": "The origin type of the notebook"
    },
    "NotebookMetadata": {
      "type": "object",
      "description": "Notebook metadata",
      "properties": {
        "originType": {
          "$ref": "#/definitions/NotebookOriginType",
          "description": "The origin type"
        },
        "originalFileName": {
          "type": "string",
          "description": "The original file name"
        },
        "originalHttpUrl": {
          "type": "string",
          "description": "The original HTTP URL"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When was created"
        }
      },
      "additionalProperties": false
    }
  }
}
