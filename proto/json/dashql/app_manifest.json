{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dashql/app_manifest.json",
  "title": "StorageManifest",
  "description": "Manifest structure for DashQL sessions (dashql-manifest.json)",
  "type": "object",
  "properties": {
    "sessions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/SessionEntry"
      },
      "description": "List of sessions"
    },
    "appSettings": {
      "$ref": "#/definitions/AppSettings",
      "description": "Persisted app-level settings"
    }
  },
  "required": ["sessions"],
  "additionalProperties": false,
  "definitions": {
    "SessionEntry": {
      "type": "object",
      "description": "Manifest entry for a session",
      "properties": {
        "path": {
          "type": "string",
          "description": "The session path (folder name)"
        }
      },
      "required": ["path"],
      "additionalProperties": false
    },
    "AppSettings": {
      "type": "object",
      "description": "Persisted app-level settings",
      "properties": {
        "httpProxyUrl": {
          "type": "string",
          "description": "Optional HTTP/CORS proxy origin. When set and the request host matches httpProxyTargetList, the shared HTTP client rewrites the request to this origin and attaches an X-Forward-To header with the original origin."
        },
        "httpProxyTargetList": {
          "type": "string",
          "description": "Comma-separated list of host patterns to route through the proxy. Entries may be exact hostnames (example.com) or wildcard patterns (*.example.com). Empty = no requests are proxied."
        }
      },
      "additionalProperties": false
    }
  }
}
