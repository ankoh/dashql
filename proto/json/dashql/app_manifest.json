{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dashql/app_manifest.json",
  "title": "StorageManifest",
  "description": "Manifest structure for DashQL sessions (dashql-manifest.json)",
  "type": "object",
  "properties": {
    "sessions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/SessionEntry"
      },
      "description": "List of sessions"
    },
    "appSettings": {
      "$ref": "#/definitions/AppSettings",
      "description": "Persisted app-level settings"
    }
  },
  "required": ["sessions"],
  "additionalProperties": false,
  "definitions": {
    "SessionEntry": {
      "type": "object",
      "description": "Manifest entry for a session",
      "properties": {
        "path": {
          "type": "string",
          "description": "The session path (folder name)"
        }
      },
      "required": ["path"],
      "additionalProperties": false
    },
    "AppSettings": {
      "type": "object",
      "description": "Persisted app-level settings",
      "properties": {
        "aiProvider": {
          "$ref": "#/definitions/AIProviderSettings",
          "description": "Configuration of the OpenAI-compatible AI provider"
        }
      },
      "additionalProperties": false
    },
    "AIProviderHeader": {
      "type": "object",
      "description": "Additional HTTP header sent with AI provider requests",
      "properties": {
        "name": {
          "type": "string",
          "description": "Header name"
        },
        "value": {
          "type": "string",
          "description": "Header value"
        }
      },
      "required": ["name", "value"],
      "additionalProperties": false
    },
    "AIProviderSettings": {
      "type": "object",
      "description": "Configuration for an OpenAI-compatible AI provider (Ollama, OpenAI, vLLM, etc.)",
      "properties": {
        "endpointUrl": {
          "type": "string",
          "description": "Base URL of the OpenAI-compatible server (e.g. http://localhost:11434)"
        },
        "model": {
          "type": "string",
          "description": "The model identifier to use for chat completions"
        },
        "headers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/AIProviderHeader"
          },
          "description": "Additional HTTP headers (e.g. Authorization)"
        }
      },
      "additionalProperties": false
    }
  }
}
