{
    "name": "@dashql/core",
    "private": true,
    "description": "DashQL Core Library",
    "license": "AGPL-3.0-or-later",
    "dependencies": {
        "cross-fetch": "^3.0.6",
        "flatbuffers": "^1.12.0",
        "fsevents": "*",
        "immutable": "^4.0.0-rc.12",
        "redux": "^4.0.5"
    },
    "devDependencies": {
        "@types/emscripten": "^1.39.4",
        "@types/flatbuffers": "^1.10.0",
        "@types/jest": "^26.0.14",
        "benny": "^3.6.14",
        "clean-webpack-plugin": "^3.0.0",
        "compression-webpack-plugin": "^7.0.0",
        "file-loader": "^6.1.0",
        "jest": "^26.4.2",
        "jest-fetch-mock": "^3.0.3",
        "jest-junit": "^12.0.0",
        "kleur": "^4.1.3",
        "ts-jest": "^26.4.1",
        "ts-loader": "^8.0.4",
        "typescript": "^4.1.3",
        "webpack": "^5.1.3",
        "webpack-cli": "^4.1.0"
    },
    "optionalDependencies": {
        "fsevents": "*"
    },
    "scripts": {
        "build:watch": "webpack --watch --progress --mode=production",
        "build": "webpack --mode=production",
        "build:test": "webpack --mode=production",
        "test": "node ./node_modules/jest/bin/jest.js --runInBand --detectOpenHandles --env=./jest.env.js",
        "test:silent": "node ./node_modules/jest/bin/jest.js --silent --runInBand --detectOpenHandles --env=./jest.env.js",
        "test:ci": "node ./node_modules/jest/bin/jest.js --silent --runInBand --detectOpenHandles --env=./jest.env.js --ci --reporters=default --reporters=jest-junit"
    },
    "files": [
        "dist/**/*.d.ts",
        "dist/**/*.js",
        "dist/*.wasm"
    ],
    "main": "./dist/dashql_core_node.js",
    "module": "./dist/dashql_core_node.js",
    "types": "./dist/index_node.d.ts",
    "browser": {
        "./dist/dashql_core_node.js": "./dist/dashql_core_web.js",
        "worker_threads": false,
        "perf_hooks": false,
        "fs": false,
        "buffer": false
    },
    "jest-junit": {
        "suiteName": "Javascript",
        "outputDirectory": "../../reports",
        "outputName": "tests_js.xml",
        "uniqueOutputName": "false",
        "classNameTemplate": "{classname}",
        "titleTemplate": "{title}",
        "ancestorSeparator": " › ",
        "usePathForSuiteName": "true"
    }
}
