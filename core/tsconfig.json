{
    "compilerOptions": {
        "outDir": "./dist/",
        "target": "es6",
        "module": "es6",
        "moduleResolution": "node",
        "sourceMap": true,
        "strict": true,
        "declaration": true,
        "declarationMap": true,
        "declarationDir": "dist",
        "noImplicitAny": true,
        "esModuleInterop": true,
        "types": ["emscripten", "jest", "node"],
        "lib": ["esnext", "dom"],
        "baseUrl": ".",
        "paths": {
            "@dashql/proto": ["../proto/index.ts"]
        }
    },
    "exclude": [
        "./test/**/*.ts",
        "./node_modules"
    ]
}
