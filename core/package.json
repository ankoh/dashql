{
    "name": "@dashql/core",
    "private": true,
    "description": "DashQL Core Library",
    "license": "AGPL-3.0-or-later",
    "dependencies": {
        "@dashql/proto": "file:../proto/",
        "@dashql/webdb": "file:../webdb/",
        "axios": "^0.21.0",
        "flatbuffers": "^1.12.0",
        "fsevents": "*",
        "hash-wasm": "^4.4.1",
        "immutable": "^4.0.0-rc.12",
        "redux": "^4.0.5"
    },
    "devDependencies": {
        "@types/emscripten": "^1.39.4",
        "@types/flatbuffers": "^1.10.0",
        "@types/jest": "^26.0.14",
        "axios-mock-adapter": "^1.19.0",
        "clean-webpack-plugin": "^3.0.0",
        "file-loader": "^6.1.0",
        "jest": "^26.4.2",
        "jest-junit": "^12.0.0",
        "ts-jest": "^26.4.1",
        "ts-loader": "^8.0.4",
        "ts-mockito": "^2.6.1",
        "typescript": "^4.1.3",
        "webpack": "^5.1.3",
        "webpack-cli": "^4.1.0",
        "webpack-node-externals": "^2.5.2"
    },
    "optionalDependencies": {
        "fsevents": "*"
    },
    "scripts": {
        "build:watch": "webpack --watch --progress --mode=production",
        "build": "webpack --mode=production",
        "build:test": "webpack --mode=production",
        "test": "node ./node_modules/.bin/jest --runInBand --detectOpenHandles --env=./jest.env.js ",
        "test:debug": "node --inspect ./node_modules/.bin/jest --runInBand --detectOpenHandles --env=./jest.env.js ",
        "test:silent": "node ./node_modules/.bin/jest --silent --runInBand --detectOpenHandles --env=./jest.env.js",
        "test:ci": "node ./node_modules/.bin/jest --silent --runInBand --detectOpenHandles --env=./jest.env.js --ci"
    },
    "files": [
        "dist/**/*.d.ts",
        "dist/**/*.js",
        "dist/*.wasm"
    ],
    "main": "./dist/dashql_core_node.js",
    "module": "./dist/dashql_core_node.js",
    "types": "./dist/types/index_node.d.ts",
    "browser": {
        "./dist/dashql_core_node.js": "./dist/dashql_core.js",
        "worker_threads": false,
        "perf_hooks": false,
        "fs": false,
        "buffer": false
    },
    "jest-junit": {
        "suiteName": "Javascript",
        "outputDirectory": "../reports",
        "outputName": "tests_core.xml",
        "uniqueOutputName": "false",
        "classNameTemplate": "{classname}",
        "titleTemplate": "{title}",
        "ancestorSeparator": " › ",
        "usePathForSuiteName": "true"
    }
}
