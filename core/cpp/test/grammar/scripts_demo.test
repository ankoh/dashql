name: demo
input: |-
  -- This script outlines basic concepts of the SQL extension DashQL.
  -- Delete everything when you're ready and start from scratch.
  
  -- Declare a dynamic input field on top of your dashboard.
  -- Ref: https://docs.dashql.com/grammar/param
  DECLARE PARAMETER country TYPE TEXT (
      default_value = 'DE'
  );
  
  -- Load data from external sources like HTTP REST APIs.
  -- Ref: https://docs.dashql.com/grammar/load
  LOAD weather_csv FROM http (
      url = format('https://cdn.dashql.com/demo/weather/%s', global.country)
  );
  
  -- Interpret the data as SQL table.
  -- Ref: https://docs.dashql.com/grammar/extract
  EXTRACT weather FROM weather_csv USING CSV;
  
  -- Run arbitrary SQL within your browser.
  -- Ref: https://docs.dashql.com/grammar/query
  SELECT 1 INTO weather_avg FROM weather;
  
  -- Visualize tables and views.
  -- Ref: https://docs.dashql.com/grammar/viz
  VIZ weather_avg USING LINE;
expected:
  statements:
    - name: global.country
      type: PARAMETER
      root:
        type: OBJECT_DASHQL_PARAMETER
        location: "237..301|`DECLARE PA`..`e = 'DE' )`"
        DASHQL_PARAMETER_TYPE: TEXT
        DASHQL_STATEMENT_NAME:
          - 255..262|`country`
        DASHQL_OPTION_DEFAULT_VALUE:
          type: OBJECT_SQL_CONST
          location: "295..300|`'DE' `"
          SQL_CONST_TYPE: STRING
          SQL_CONST_VALUE: "295..300|`'DE' `"
    - name: global.weather_csv
      type: LOAD_HTTP
      root:
        type: OBJECT_DASHQL_LOAD
        location: 405..510|`LOAD weath`..`country) )`
        DASHQL_LOAD_METHOD: HTTP
        DASHQL_STATEMENT_NAME:
          - 410..421|`weather_csv`
        DASHQL_OPTION_URL:
          type: OBJECT_DASHQL_FUNCTION_CALL
          location: "444..508|`format('ht`..`l.country)`"
          SQL_FUNCTION_ARGUMENTS:
            - type: OBJECT_SQL_CONST
              location: "451..491|`'https://c`..`eather/%s'`"
              SQL_CONST_TYPE: STRING
              SQL_CONST_VALUE: "451..491|`'https://c`..`eather/%s'`"
            - type: OBJECT_SQL_COLUMN_REF
              location: 493..507|`global.country`
              SQL_COLUMN_REF_PATH:
                - 493..499|`global`
                - 500..507|`country`
          SQL_FUNCTION_NAME: 444..450|`format`
    - name: global.weather
      type: NONE
      root:
        type: OBJECT_DASHQL_EXTRACT
        location: 597..639|`EXTRACT we`..` USING CSV`
        DASHQL_EXTRACT_DATA:
          - 618..629|`weather_csv`
        DASHQL_EXTRACT_METHOD: CSV
        DASHQL_STATEMENT_NAME:
          - 605..612|`weather`
    - name: global.weather_avg
      type: SELECT_INTO
      root:
        type: OBJECT_DASHQL_QUERY
        location: 730..768|`SELECT 1 I`..`OM weather`
        DASHQL_QUERY_STATEMENT:
          type: OBJECT_SQL_SELECT
          location: 730..768|`SELECT 1 I`..`OM weather`
          SQL_SELECT_FROM:
            - type: OBJECT_SQL_TABLE_REF
              location: 761..768|`weather`
              SQL_TABLE_INHERIT: true
              SQL_TABLE_NAME:
                - 761..768|`weather`
          SQL_SELECT_INTO:
            type: OBJECT_SQL_INTO
            location: 744..755|`weather_avg`
            SQL_TEMP_NAME:
              - 744..755|`weather_avg`
            SQL_TEMP_TYPE: DEFAULT
          SQL_SELECT_TARGETS:
            - type: OBJECT_SQL_CONST
              location: 737..738|`1`
              SQL_CONST_TYPE: INTEGER
              SQL_CONST_VALUE: 737..738|`1`
    - name: global.weather_avg
      type: VIZUALIZE
      root:
        type: OBJECT_DASHQL_VIZ
        location: 846..872|`VIZ weathe`..`USING LINE`
        DASHQL_VIZ_TARGET:
          type: OBJECT_SQL_TABLE_REF
          location: 850..861|`weather_avg`
          SQL_TABLE_INHERIT: true
          SQL_TABLE_NAME:
            - 850..861|`weather_avg`
        DASHQL_VIZ_TYPE: LINE
  errors: []
  line_breaks:
    - 67..68|` `
    - 130..131|` `
    - 131..132|` `
    - 190..191|` `
    - 236..237|` `
    - 274..275|` `
    - 299..300|` `
    - 302..303|` `
    - 303..304|` `
    - 359..360|` `
    - 404..405|` `
    - 433..434|` `
    - 508..509|` `
    - 511..512|` `
    - 512..513|` `
    - 548..549|` `
    - 596..597|` `
    - 640..641|` `
    - 641..642|` `
    - 683..684|` `
    - 729..730|` `
    - 769..770|` `
    - 770..771|` `
    - 801..802|` `
    - 845..846|` `
  comments:
    - '0..67|`-- This sc`..`on DashQL.`'
    - '68..130|`-- Delete `..`m scratch.`'
    - '132..190|`-- Declare`..`dashboard.`'
    - '191..236|`-- Ref: ht`..`mmar/param`'
    - '304..359|`-- Load da`..`REST APIs.`'
    - '360..404|`-- Ref: ht`..`ammar/load`'
    - '513..548|`-- Interpr`..`SQL table.`'
    - '549..596|`-- Ref: ht`..`ar/extract`'
    - '642..683|`-- Run arb`..`r browser.`'
    - '684..729|`-- Ref: ht`..`mmar/query`'
    - '771..801|`-- Visuali`..`and views.`'
    - '802..845|`-- Ref: ht`..`rammar/viz`'
  dependencies:
    - type: COLUMN_REF
      source: 0
      target: 1
      target_node: 493..507|`global.country`
    - type: TABLE_REF
      source: 1
      target: 2
      target_node: 618..629|`weather_csv`
    - type: TABLE_REF
      source: 2
      target: 3
      target_node: 761..768|`weather`
    - type: TABLE_REF
      source: 3
      target: 4
      target_node: 850..861|`weather_avg`
