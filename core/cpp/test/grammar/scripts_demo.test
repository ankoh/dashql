name: demo
input: |-
  -- This script outlines basic concepts of the SQL extension DashQL.
  -- Delete everything when you're ready and start from scratch.
  
  -- Declare a dynamic input field on top of your dashboard.
  -- Ref: https://docs.dashql.com/grammar/param
  DECLARE PARAMETER country TYPE TEXT (
      default_value = 'DE'
  );
  
  -- Load data from external sources like HTTP REST APIs.
  -- Ref: https://docs.dashql.com/grammar/load
  LOAD wheather_csv FROM http (
      url = 'https://cdn.dashql.com/demo/weather/{{country}}'
  );
  
  -- Interpret the data as SQL table.
  -- Ref: https://docs.dashql.com/grammar/extract
  EXTRACT wheather FROM wheather_csv USING CSV;
  
  -- Run arbitrary SQL within your browser.
  -- Ref: https://docs.dashql.com/grammar/query
  SELECT 1 INTO weather_avg FROM wheather;
  
  -- Visualize tables and views.
  -- Ref: https://docs.dashql.com/grammar/viz
  VIZ weather_avg USING LINE;
expected:
  statements:
    - name: global.country
      root:
        type: OBJECT_DASHQL_PARAMETER
        location: "237..301|`DECLARE PA`..`e = 'DE'\n)`"
        DASHQL_PARAMETER_IDENTIFIER: 255..262|`country`
        DASHQL_PARAMETER_TYPE: TEXT
        DASHQL_OPTION_DEFAULT_VALUE: "295..300|`'DE'\n`"
    - root:
        type: OBJECT_DASHQL_LOAD
        location: "405..496|`LOAD wheat`..`untry}}'\n)`"
        DASHQL_LOAD_METHOD: HTTP
        DASHQL_LOAD_NAME: 410..422|`wheather_csv`
        DASHQL_OPTION_URL: "445..495|`'https://c`..`ountry}}'\n`"
    - root:
        type: OBJECT_DASHQL_EXTRACT
        location: 583..627|`EXTRACT wh`..` USING CSV`
        DASHQL_EXTRACT_DATA: 605..617|`wheather_csv`
        DASHQL_EXTRACT_METHOD: CSV
        DASHQL_EXTRACT_NAME: 591..599|`wheather`
    - name: global.weather_avg
      root:
        type: OBJECT_DASHQL_QUERY
        location: 718..757|`SELECT 1 I`..`M wheather`
        DASHQL_QUERY_STATEMENT:
          type: OBJECT_SQL_SELECT
          location: 718..757|`SELECT 1 I`..`M wheather`
          SQL_SELECT_FROM:
            - type: OBJECT_SQL_TABLE_REF
              location: 749..757|`wheather`
              SQL_TABLE_INHERIT: true
              SQL_TABLE_NAME:
                - 749..757|`wheather`
          SQL_SELECT_INTO:
            type: OBJECT_SQL_INTO
            location: 732..743|`weather_avg`
            SQL_TEMP_NAME:
              - 732..743|`weather_avg`
            SQL_TEMP_TYPE: DEFAULT
          SQL_SELECT_TARGETS:
            - type: OBJECT_SQL_ACONST
              location: 725..726|`1`
              SQL_ACONST_TYPE: INTEGER
    - root:
        type: OBJECT_DASHQL_VIZ
        location: 835..861|`VIZ weathe`..`USING LINE`
        DASHQL_VIZ_TARGET: 839..850|`weather_avg`
        DASHQL_VIZ_TYPE: LINE
  errors: []
  line_breaks:
    - 67..68|`\n`
    - 130..131|`\n`
    - 131..132|`\n`
    - 190..191|`\n`
    - 236..237|`\n`
    - 274..275|`\n`
    - 299..300|`\n`
    - 302..303|`\n`
    - 303..304|`\n`
    - 359..360|`\n`
    - 404..405|`\n`
    - 434..435|`\n`
    - 494..495|`\n`
    - 497..498|`\n`
    - 498..499|`\n`
    - 534..535|`\n`
    - 582..583|`\n`
    - 628..629|`\n`
    - 629..630|`\n`
    - 671..672|`\n`
    - 717..718|`\n`
    - 758..759|`\n`
    - 759..760|`\n`
    - 790..791|`\n`
    - 834..835|`\n`
  comments:
    - '0..67|`-- This sc`..`on DashQL.`'
    - '68..130|`-- Delete `..`m scratch.`'
    - '132..190|`-- Declare`..`dashboard.`'
    - '191..236|`-- Ref: ht`..`mmar/param`'
    - '304..359|`-- Load da`..`REST APIs.`'
    - '360..404|`-- Ref: ht`..`ammar/load`'
    - '499..534|`-- Interpr`..`SQL table.`'
    - '535..582|`-- Ref: ht`..`ar/extract`'
    - '630..671|`-- Run arb`..`r browser.`'
    - '672..717|`-- Ref: ht`..`mmar/query`'
    - '760..790|`-- Visuali`..`and views.`'
    - '791..834|`-- Ref: ht`..`rammar/viz`'
  interpolations:
    - '482..493|`{{country}}`'
  dependencies: []
