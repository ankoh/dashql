name: demo
input: |-
  -- This script outlines basic concepts of the SQL extension DashQL.
  -- Delete everything when you're ready and start from scratch.
  
  -- Declare a dynamic input field on top of your dashboard.
  -- Ref: https://docs.dashql.com/grammar/param
  DECLARE PARAMETER country TYPE TEXT (
      default_value = 'DE'
  );
  
  -- Load data from external sources like HTTP REST APIs.
  -- Ref: https://docs.dashql.com/grammar/load
  LOAD wheather_csv FROM http (
      url = format('https://cdn.dashql.com/demo/weather/%s', global.country)
  );
  
  -- Interpret the data as SQL table.
  -- Ref: https://docs.dashql.com/grammar/extract
  EXTRACT wheather FROM wheather_csv USING CSV;
  
  -- Run arbitrary SQL within your browser.
  -- Ref: https://docs.dashql.com/grammar/query
  SELECT 1 INTO weather_avg FROM wheather;
  
  -- Visualize tables and views.
  -- Ref: https://docs.dashql.com/grammar/viz
  VIZ weather_avg USING LINE;
expected:
  statements:
    - name: global.country
      root:
        type: OBJECT_DASHQL_PARAMETER
        location: "237..301|`DECLARE PA`..`e = 'DE' )`"
        DASHQL_PARAMETER_TYPE: TEXT
        DASHQL_STATEMENT_NAME:
          - 255..262|`country`
        DASHQL_OPTION_DEFAULT_VALUE:
          type: OBJECT_SQL_CONST
          location: "295..300|`'DE' `"
          SQL_CONST_TYPE: STRING
    - name: global.wheather_csv
      root:
        type: OBJECT_DASHQL_LOAD
        location: 405..511|`LOAD wheat`..`country) )`
        DASHQL_LOAD_METHOD: HTTP
        DASHQL_STATEMENT_NAME:
          - 410..422|`wheather_csv`
        DASHQL_OPTION_URL:
          type: OBJECT_DASHQL_FUNCTION_CALL
          location: "445..509|`format('ht`..`l.country)`"
          SQL_FUNCTION_ARGUMENTS:
            - type: OBJECT_SQL_CONST
              location: "452..492|`'https://c`..`eather/%s'`"
              SQL_CONST_TYPE: STRING
            - type: OBJECT_SQL_COLUMN_REF
              location: 494..508|`global.country`
              SQL_COLUMN_REF_PATH:
                - 494..500|`global`
                - 501..508|`country`
          SQL_FUNCTION_NAME: 445..451|`format`
    - name: global.wheather
      root:
        type: OBJECT_DASHQL_EXTRACT
        location: 598..642|`EXTRACT wh`..` USING CSV`
        DASHQL_EXTRACT_DATA:
          - 620..632|`wheather_csv`
        DASHQL_EXTRACT_METHOD: CSV
        DASHQL_STATEMENT_NAME:
          - 606..614|`wheather`
    - name: global.weather_avg
      root:
        type: OBJECT_DASHQL_QUERY
        location: 733..772|`SELECT 1 I`..`M wheather`
        DASHQL_QUERY_STATEMENT:
          type: OBJECT_SQL_SELECT
          location: 733..772|`SELECT 1 I`..`M wheather`
          SQL_SELECT_FROM:
            - type: OBJECT_SQL_TABLE_REF
              location: 764..772|`wheather`
              SQL_TABLE_INHERIT: true
              SQL_TABLE_NAME:
                - 764..772|`wheather`
          SQL_SELECT_INTO:
            type: OBJECT_SQL_INTO
            location: 747..758|`weather_avg`
            SQL_TEMP_NAME:
              - 747..758|`weather_avg`
            SQL_TEMP_TYPE: DEFAULT
          SQL_SELECT_TARGETS:
            - type: OBJECT_SQL_CONST
              location: 740..741|`1`
              SQL_CONST_TYPE: INTEGER
    - root:
        type: OBJECT_DASHQL_VIZ
        location: 850..876|`VIZ weathe`..`USING LINE`
        DASHQL_VIZ_TARGET:
          type: OBJECT_SQL_TABLE_REF
          location: 854..865|`weather_avg`
          SQL_TABLE_INHERIT: true
          SQL_TABLE_NAME:
            - 854..865|`weather_avg`
        DASHQL_VIZ_TYPE: LINE
  errors: []
  line_breaks:
    - 67..68|` `
    - 130..131|` `
    - 131..132|` `
    - 190..191|` `
    - 236..237|` `
    - 274..275|` `
    - 299..300|` `
    - 302..303|` `
    - 303..304|` `
    - 359..360|` `
    - 404..405|` `
    - 434..435|` `
    - 509..510|` `
    - 512..513|` `
    - 513..514|` `
    - 549..550|` `
    - 597..598|` `
    - 643..644|` `
    - 644..645|` `
    - 686..687|` `
    - 732..733|` `
    - 773..774|` `
    - 774..775|` `
    - 805..806|` `
    - 849..850|` `
  comments:
    - '0..67|`-- This sc`..`on DashQL.`'
    - '68..130|`-- Delete `..`m scratch.`'
    - '132..190|`-- Declare`..`dashboard.`'
    - '191..236|`-- Ref: ht`..`mmar/param`'
    - '304..359|`-- Load da`..`REST APIs.`'
    - '360..404|`-- Ref: ht`..`ammar/load`'
    - '514..549|`-- Interpr`..`SQL table.`'
    - '550..597|`-- Ref: ht`..`ar/extract`'
    - '645..686|`-- Run arb`..`r browser.`'
    - '687..732|`-- Ref: ht`..`mmar/query`'
    - '775..805|`-- Visuali`..`and views.`'
    - '806..849|`-- Ref: ht`..`rammar/viz`'
  dependencies:
    - type: COLUMN_REF
      source: 0
      target: 1
      target_node: 494..508|`global.country`
    - type: TABLE_REF
      source: 1
      target: 2
      target_node: 620..632|`wheather_csv`
    - type: TABLE_REF
      source: 2
      target: 3
      target_node: 764..772|`wheather`
    - type: TABLE_REF
      source: 3
      target: 4
      target_node: 854..865|`weather_avg`
