<test name="update_parameter_value">
    <previous>
        <text>
            DECLARE PARAMETER country TYPE TEXT (
                default_value = 'DE'
            );
            LOAD weather_csv FROM http (
                url = format('https://cdn.dashql.com/demo/weather/%s', global.country)
            );
        </text>
        <parameters>
            <parameter type="TEXT" statement="0" value="DE" />
        </parameters>
        <graph next_target_id="2">
            <setup />
            <program>
                <action type="PARAMETER" status="COMPLETED" statement="0">
                    <target id="0" name_qualified="global.country" name_short="country" />
                    <required_for>
                        <ref action="1" />
                    </required_for>
                </action>
                <action type="LOAD_HTTP" status="NONE" statement="1">
                    <target id="1" name_qualified="global.weather_csv" name_short="weather_csv" />
                    <depends_on>
                        <ref action="0" />
                    </depends_on>
                </action>
            </program>
        </graph>
    </previous>
    <next>
        <text>
            DECLARE PARAMETER country TYPE TEXT (
                default_value = 'DE'
            );
            LOAD weather_csv FROM http (
                url = format('https://cdn.dashql.com/demo/weather/%s', global.country)
            );
        </text>
        <parameters>
            <parameter type="TEXT" statement="0" value="US" />
        </parameters>
        <graph next_target_id="4">
            <setup>
                <action type="DROP_BLOB">
                    <target id="0" name_qualified="global.weather_csv" name_short="weather_csv" />
                </action>
            </setup>
            <program>
                <action type="PARAMETER" status="NONE" statement="0">
                    <target id="2" name_qualified="global.country" name_short="country" />
                    <required_for>
                        <ref action="1" />
                    </required_for>
                </action>
                <action type="LOAD_HTTP" status="NONE" statement="1">
                    <target id="3" name_qualified="global.weather_csv" name_short="weather_csv" />
                    <depends_on>
                        <ref action="0" />
                    </depends_on>
                </action>
            </program>
        </graph>
    </next>
</test>
