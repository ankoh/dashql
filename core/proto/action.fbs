include "action_config.fbs";

namespace dashql.proto.action;

// ---------------------------------------------------------------------------
// Action graph

enum ActionType: uint8 {
    NONE = 0,

    // State actions
    STATE_MIN = 10,
    DROP_LOAD = 20,
    LOAD_FILE = 21,
    LOAD_HTTP = 22,
    DROP_EXTRACT = 30,
    EXTRACT_JSON = 31,
    EXTRACT_CSV = 32,
    DROP_VIEW = 40,
    CREATE_VIEW = 41,
    DROP_TABLE = 50,
    CREATE_TABLE = 51,
    MODIFY_TABLE = 52,
    DROP_VIZ = 60,
    CREATE_VIZ = 61,
    UPDATE_VIZ = 62,

    // Volatile Actions
    VOLATILE_MIN = 100,
    QUERY_SCALAR = 101,
    QUERY_TABLE = 102,
}

union ActionConfig {
    // State actions
    LoadFileAction,
    LoadHTTPAction,
    DropLoadAction,
    ExtractJSONAction,
    ExtractCSVAction,
    DropExtractAction,
    CreateViewAction,
    DropViewAction,
    CreateTableAction,
    ModifyTableAction,
    DropTableAction,
    CreateVizAction,
    UpdateVizAction,
    DropVizAction,

    // Volatile actions
    QueryScalarAction,
    QueryTableAction,
}

table Action {
    action_type: ActionType;
    origin_statement: uint32;
    required_actions: [uint32];
    action_config: ActionConfig;
}

table ActionGraph {
    actions: [Action];
}

// ---------------------------------------------------------------------------
// Action status

enum ActionStatusCode: uint8 {
    NONE = 0,
    PREPARING = 1,
    BLOCKED = 2,
    RUNNING = 4,
    COMPLETED = 5,
    ERROR = 6,
}

enum ActionBlocker: uint8 {
    NONE = 0,
    DEPENDENCY = 1,
    USER_INTERACTION = 2,
    HTTP_REQUEST = 3,
    SCHEDULER = 4,
}

struct ActionStatus {
    status_code: ActionStatusCode;
    blocker: ActionBlocker;
    last_update: uint64;
}
