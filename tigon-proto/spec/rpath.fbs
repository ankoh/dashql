namespace tigon.proto;

table RPathArraySlice {}

table RPathArrayIndexes {}

table RPathChildMember {}

table RPathDescendantMember {}

union RPathComponent {
    RPathArraySlice,
    RPathArrayIndexes,
    RPathChildMember,
    RPathDescendantMember,
}

table RPath {
    components: [RPathComponent];
}
