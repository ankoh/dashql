{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "esnext"
    ],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "esnext",
    "moduleResolution": "node",
    "strictPropertyInitialization": false,

    "outDir": "lib",
    "sourceMap": true,
    "declaration": true
  },
  "include": [
    "src"
  ]
}
