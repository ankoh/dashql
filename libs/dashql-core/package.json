{
    "name": "@dashql/dashql-core",
    "version": "0.1.0",
    "license": "MPL-2.0",
    "private": true,
    "scripts": {
        "wasm:debug": "node build_wasm.mjs debug && tsc --emitDeclarationOnly",
        "wasm:release": "node build_wasm.mjs release && tsc --emitDeclarationOnly",
        "node:debug": "node build_node.mjs debug && tsc --emitDeclarationOnly",
        "node:release": "node build_node.mjs release && tsc --emitDeclarationOnly"
    },
    "files": [
        "dist"
    ],
    "devDependencies": {
        "@types/jasmine": "^4.0.3",
        "cargo-cp-artifact": "^0.1",
        "jasmine": "^4.1.0",
        "jasmine-core": "^4.1.1",
        "jasmine-spec-reporter": "^7.0.0",
        "rimraf": "^3.0.2",
        "make-dir": "^3.1.0",
        "esbuild": "^0.14.39",
        "apache-arrow": "^8.0.0"
    },
    "sideEffects": false,
    "exports": {
        "./dist/wasm": {
            "types": "./dist/wasm/index.d.ts",
            "import": "./dist/wasm/index.mjs",
            "require": "./dist/wasm/index.mjs"
        },
        "./dist/node": {
            "types": "./dist/node/index.d.ts",
            "import": "./dist/node/index.cjs",
            "require": "./dist/node/index.cjs"
        },
        ".": {
            "browser": {
                "types": "./dist/wasm/index.d.ts",
                "import": "./dist/wasm/index.mjs",
                "require": "./dist/wasm/index.mjs"
            },
            "node": {
                "types": "./dist/node/index.d.ts",
                "import": "./dist/node/index.cjs",
                "require": "./dist/node/index.cjs"
            },
            "types": "./dist/wasm/index.d.ts",
            "import": "./dist/wasm/index.mjs",
            "require": "./dist/wasm/index.mjs"
        }
    }
}
