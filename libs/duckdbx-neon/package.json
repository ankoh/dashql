{
    "name": "duckdbx-neon",
    "version": "0.1.0",
    "description": "",
    "scripts": {
        "build:debug": "yarn run compile:debug && yarn run bundle:debug",
        "build:release": "yarn run compile:release && yarn run bundle:release",
        "bundle:debug": "node bundle.mjs debug",
        "bundle:release": "node bundle.mjs release",
        "compile": "cargo-cp-artifact -nc ./dist/duckdbx.node -- cargo build --message-format=json-render-diagnostics",
        "compile:debug": "yarn run compile",
        "compile:release": "yarn run compile --release",
        "install": "yarn run build:release",
        "test": "node --enable-source-maps ../../node_modules/jasmine/bin/jasmine ./dist/tests-node.cjs"
    },
    "main": "dist/duckdbx.cjs",
    "files": [
        "dist"
    ],
    "author": "",
    "license": "MPL-2.0",
    "devDependencies": {
        "@types/jasmine": "^4.0.3",
        "cargo-cp-artifact": "^0.1",
        "jasmine": "^4.1.0",
        "jasmine-core": "^4.1.1",
        "jasmine-spec-reporter": "^7.0.0",
        "rimraf": "^3.0.2",
        "make-dir": "^3.1.0",
        "esbuild": "^0.14.39"
    }
}
