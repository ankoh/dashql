name: select_iconst_1_ident
input: |-
  select 1 "foo";
expected:
  statements:
    - type: DASHQL_QUERY 
      location: '0..14|`select 1 "foo"`'
      DASHQL_QUERY_STATEMENT:
        type: SQL_SELECT
        location: '0..14|`select 1 "foo"`'
        SQL_SELECT_TARGETS:
          - type: SQL_RESULT_TARGET
            location: '7..14|`1 "foo"`'
            SQL_RESULT_TARGET_VALUE:
              type: SQL_ACONST
              location: 7..8|`1`
              SQL_ACONST_TYPE: 0
              SQL_ACONST_VALUE: 1
            SQL_RESULT_TARGET_NAME: '9..14|`"foo"`'
  errors: []
  line_breaks: []
  comments: []
