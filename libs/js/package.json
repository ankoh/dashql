{
    "name": "@dashql/parser",
    "version": "0.0.2",
    "description": "Parser for the DashQL language",
    "author": "Andre Kohn <kohn.a@outlook.com>",
    "license": "AGPL3",
    "dependencies": {
        "flatbuffers": "^1.12.0"
    },
    "devDependencies": {
        "@types/emscripten": "^1.39.4",
        "@types/flatbuffers": "^1.10.0",
        "@types/jest": "^26.0.14",
        "@types/text-encoding": "0.0.35",
        "benny": "^3.6.14",
        "clean-webpack-plugin": "^3.0.0",
        "file-loader": "^6.1.0",
        "jest": "^26.4.2",
        "jest-junit": "^12.0.0",
        "kleur": "^4.1.3",
        "ts-jest": "^26.4.1",
        "ts-loader": "^8.0.4",
        "typescript": "^4.0.3",
        "webpack": "^4.44.2",
        "webpack-cli": "^3.3.12",
        "webpack-node-externals": "^2.5.2"
    },
    "scripts": {
        "start": "webpack --progress --colors --watch",
        "build": "webpack --mode=production",
        "test": "node --experimental-wasm-threads --experimental-wasm-bulk-memory ./node_modules/jest/bin/jest.js",
        "test:ci": "node --experimental-wasm-threads --experimental-wasm-bulk-memory ./node_modules/jest/bin/jest.js --ci --reporters=default --reporters=jest-junit"
    },
    "files": [
        "dist/**/*.d.ts",
        "dist/**/*.js",
        "dist/*.wasm"
    ],
    "main": "./dist/targets/node/dashql_parser.js",
    "types": "./dist/targets/node/dashql_parser.d.ts",
    "browser": {
        "./dist/targets/node/dashql_parser.js": "./dist/targets/web/dashql_parser.js",
        "worker_threads": false,
        "perf_hooks": false,
        "fs": false,
        "buffer": false
    },
    "jest-junit": {
        "suiteName": "Javascript",
        "outputDirectory": "../../reports",
        "outputName": "tests_js.xml",
        "uniqueOutputName": "false",
        "classNameTemplate": "{classname}",
        "titleTemplate": "{title}",
        "ancestorSeparator": " › ",
        "usePathForSuiteName": "true"
    }
}
