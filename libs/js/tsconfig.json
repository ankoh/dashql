{
    "compilerOptions": {
        "outDir": "./dist/",
        "target": "es5",
        "module": "es6",
        "moduleResolution": "node",
        "sourceMap": false,
        "declaration": true,
        "declarationMap": true,
        "declarationDir": "./dist",
        "noImplicitAny": true,
        "esModuleInterop": true,
        "types": ["emscripten", "jest"]
    },
    "exclude": [
        "./test/**/*.ts",
        "./node_modules"
    ]
}
