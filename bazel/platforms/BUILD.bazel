# Platform for building C/C++ to WebAssembly (wasm32-wasi).
# dist_wasm / tests apply this via use_wasm32_platform transition (no --config=wasm needed).
# Direct build: bazel build --platforms=//bazel/platforms:wasm32 --modify_execution_info=.*=+no-sandbox //packages/dashql-core:dashql_core_wasm

package(default_visibility = ["//visibility:public"])

platform(
    name = "wasm32",
    constraint_values = [
        "@platforms//cpu:wasm32",
        "@platforms//os:none",
    ],
)
