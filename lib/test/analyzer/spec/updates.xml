<tests>
    <test name="parameter_update_load">
        <step>
            <text>
                INPUT country TYPE string USING TEXT (
                    default_value = 'DE'
                );
                FETCH weather_csv FROM http (
                    url = format('https://cdn.dashql.com/demo/weather/{}', main.country)
                );
            </text>
            <inputs>
                <input statement="0" type="string" value="DE" />
            </inputs>
            <evaluations>
                <eval type="string" value="'https://cdn.dashql.com/demo/weather/DE'" loc="188..250" text="format('ht..n.country)" />
            </evaluations>
            <cards>
                <input name="country" component="TEXT" />
            </cards>
            <graph next_object_id="2">
                <setup />
                <program>
                    <action type="INPUT" status="COMPLETED" object_id="0" statement="0">
                        <output name="main.country" />
                        <required_for>
                            <ref action="1" />
                        </required_for>
                    </action>
                    <action type="FETCH" status="PENDING" object_id="1" statement="1">
                        <output name="main.weather_csv" />
                        <depends_on>
                            <ref action="0" />
                        </depends_on>
                    </action>
                </program>
            </graph>
        </step>
        <step>
            <text>
                INPUT country TYPE string USING TEXT (
                    default_value = 'DE'
                );
                FETCH weather_csv FROM http (
                    url = format('https://cdn.dashql.com/demo/weather/{}', main.country)
                );
            </text>
            <inputs>
                <input statement="0" type="string" value="US" />
            </inputs>
            <evaluations>
                <eval type="string" value="'https://cdn.dashql.com/demo/weather/US'" loc="188..250" text="format('ht..n.country)" />
            </evaluations>
            <cards>
                <input name="country" component="TEXT" />
            </cards>
            <graph next_object_id="4">
                <setup>
                    <action type="DROP_INPUT" status="PENDING" object_id="0">
                        <output name="main.country" />
                    </action>
                    <action type="DROP_BLOB" status="PENDING" object_id="1">
                        <output name="main.weather_csv" />
                    </action>
                </setup>
                <program>
                    <action type="INPUT" status="SKIPPED" object_id="2" statement="0">
                        <output name="main.country" />
                        <required_for>
                            <ref action="1" />
                        </required_for>
                    </action>
                    <action type="FETCH" status="SKIPPED" object_id="3" statement="1">
                        <output name="main.weather_csv" />
                        <depends_on>
                            <ref action="0" />
                        </depends_on>
                    </action>
                </program>
            </graph>
        </step>
    </test>
    <test name="position_update_view_changed_1">
        <step>
            <text>
                CREATE VIEW foo AS
                    SELECT a1::INTEGER AS a
                    FROM generate_series(0, 1000000) AS a(a1);

                VIZ foo USING TABLE;
            </text>
            <inputs />
            <evaluations />
            <cards>
                <visualization target="main.foo">
                    <components>
                        <component type="TABLE">{}</component>
                    </components>
                </visualization>
            </cards>
            <graph next_object_id="2">
                <setup />
                <program>
                    <action type="CREATE_VIEW" status="COMPLETED" object_id="0" statement="0">
                        <output name="main.foo" />
                        <required_for>
                            <ref action="1" />
                        </required_for>
                        <script>CREATE VIEW foo AS
                    SELECT a1::INTEGER AS a
                    FROM generate_series(0, 1000000) AS a(a1)</script>
                    </action>
                    <action type="CREATE_VIZ" status="PENDING" object_id="1" statement="1">
                        <depends_on>
                            <ref action="0" />
                        </depends_on>
                    </action>
                </program>
            </graph>
        </step>
        <step>
            <text>
                CREATE VIEW foo AS
                    SELECT a1::INTEGER AS a
                    FROM generate_series(0, 1000000) AS a(a1);

                VIZ foo USING TABLE (
                    pos = (r = 5, c = 1, w = 8, h = 4)
                );
            </text>
            <inputs />
            <evaluations />
            <cards>
                <visualization target="main.foo">
                    <components>
                        <component type="TABLE">{}</component>
                    </components>
                </visualization>
            </cards>
            <graph next_object_id="4">
                <setup>
                    <action type="IMPORT_VIEW" status="PENDING" object_id="0">
                        <output name="main.foo" />
                    </action>
                </setup>
                <program>
                    <action type="CREATE_VIEW" status="COMPLETED" object_id="0" statement="0">
                        <output name="main.foo" />
                        <required_for>
                            <ref action="1" />
                        </required_for>
                        <script>CREATE VIEW foo AS
                    SELECT a1::INTEGER AS a
                    FROM generate_series(0, 1000000) AS a(a1)</script>
                    </action>
                    <action type="UPDATE_VIZ" status="PENDING" object_id="1" statement="1">
                        <depends_on>
                            <ref action="0" />
                        </depends_on>
                    </action>
                </program>
            </graph>
        </step>
    </test>
