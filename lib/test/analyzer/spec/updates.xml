<test name="parameter_update_load">
    <step>
        <text>
            DECLARE PARAMETER country TYPE TEXT (
                default_value = 'DE'
            );
            LOAD weather_csv FROM http (
                url = format('https://cdn.dashql.com/demo/weather/{}', global.country)
            );
        </text>
        <parameters>
            <parameter statement="0" type="VARCHAR" value="DE" />
        </parameters>
        <evaluations>
            <eval type="VARCHAR" value="'https://cdn.dashql.com/demo/weather/DE'" loc="166..230" text="format('ht..l.country)" />
        </evaluations>
        <visualizations />
        <graph next_object_id="2">
            <setup />
            <program>
                <action origin="0" type="PARAMETER" status="COMPLETED" object_id="0">
                    <target name_qualified="global.country" name_short="country" />
                    <required_for>
                        <ref action="1" />
                    </required_for>
                </action>
                <action origin="1" type="LOAD_HTTP" status="NONE" object_id="1">
                    <target name_qualified="global.weather_csv" name_short="weather_csv" />
                    <depends_on>
                        <ref action="0" />
                    </depends_on>
                </action>
            </program>
        </graph>
    </step>
    <step>
        <text>
            DECLARE PARAMETER country TYPE TEXT (
                default_value = 'DE'
            );
            LOAD weather_csv FROM http (
                url = format('https://cdn.dashql.com/demo/weather/{}', global.country)
            );
        </text>
        <parameters>
            <parameter statement="0" type="VARCHAR" value="US" />
        </parameters>
        <evaluations>
            <eval type="VARCHAR" value="'https://cdn.dashql.com/demo/weather/US'" loc="166..230" text="format('ht..l.country)" />
        </evaluations>
        <visualizations />
        <graph next_object_id="4">
            <setup>
                <action type="DROP_BLOB" status="NONE" object_id="1">
                    <target name_qualified="global.weather_csv" name_short="weather_csv" />
                </action>
            </setup>
            <program>
                <action origin="0" type="PARAMETER" status="NONE" object_id="2">
                    <target name_qualified="global.country" name_short="country" />
                    <required_for>
                        <ref action="1" />
                    </required_for>
                </action>
                <action origin="1" type="LOAD_HTTP" status="NONE" object_id="3">
                    <target name_qualified="global.weather_csv" name_short="weather_csv" />
                    <depends_on>
                        <ref action="0" />
                    </depends_on>
                </action>
            </program>
        </graph>
    </step>
</test>
<test name="position_update_view_changed">
    <step>
        <text>
            CREATE VIEW foo AS
                SELECT a1::INTEGER AS a
                FROM generate_series(0, 1000000) AS a(a1);

            VIZ foo USING TABLE;
        </text>
        <parameters />
        <evaluations />
        <visualizations>
            <visualization>
                <target loc="148..151" text="foo" />
                <components>
                    <component type="TABLE">
                        <spec>null</spec>
                    </component>
                </components>
            </visualization>
        </visualizations>
        <graph next_object_id="2">
            <setup />
            <program>
                <action origin="0" type="CREATE_VIEW" status="COMPLETED" object_id="0">
                    <target name_qualified="global.foo" name_short="foo" />
                    <required_for>
                        <ref action="1" />
                    </required_for>
                    <script>CREATE VIEW foo AS
                SELECT a1::INTEGER AS a
                FROM generate_series(0, 1000000) AS a(a1)</script>
                </action>
                <action origin="1" type="CREATE_VIZ" status="NONE" object_id="1">
                    <target name_qualified="global.foo" name_short="foo" />
                    <depends_on>
                        <ref action="0" />
                    </depends_on>
                </action>
            </program>
        </graph>
    </step>
    <step>
        <text>
            CREATE VIEW foo AS
