    <test name="sql_table_drops">
        <step>
            <text>
                CREATE TABLE table1(a INTEGER);
                CREATE TABLE table2(a INTEGER);
            </text>
            <inputs />
            <evaluations />
            <cards />
            <graph next_object_id="2">
                <setup />
                <program>
                    <action type="CREATE_TABLE" status="COMPLETED" object_id="0" statement="0">
                        <output name="main.table1" />
                        <script>CREATE TABLE table1(a INTEGER)</script>
                    </action>
                    <action type="CREATE_TABLE" status="COMPLETED" object_id="1" statement="1">
                        <output name="main.table2" />
                        <script>CREATE TABLE table2(a INTEGER)</script>
                    </action>
                </program>
            </graph>
        </step>
        <step>
            <text>
                CREATE TABLE table1(a DOUBLE);
                CREATE TABLE table3(a INTEGER);
            </text>
            <inputs />
            <evaluations />
            <cards />
            <graph next_object_id="4">
                <setup>
                    <action type="DROP_TABLE" status="PENDING" object_id="0">
                        <output name="main.table1" />
                    </action>
                    <action type="DROP_TABLE" status="PENDING" object_id="1">
                        <output name="main.table2" />
                    </action>
                </setup>
                <program>
                    <action type="CREATE_TABLE" status="PENDING" object_id="2" statement="0">
                        <output name="main.table1" />
                        <script>CREATE TABLE table1(a DOUBLE)</script>
                    </action>
                    <action type="CREATE_TABLE" status="PENDING" object_id="3" statement="1">
                        <output name="main.table3" />
                        <script>CREATE TABLE table3(a INTEGER)</script>
                    </action>
                </program>
            </graph>
        </step>
    </test>
</tests>
