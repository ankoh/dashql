    <test name="dashql_transform_3">
        <input>
            FETCH covid_raw FROM 'https://static.dashql.com/data/test/covid_i3_overview_2021_07_23.json';

            TRANSFORM covid_raw INTO covid_history USING JMESPATH (
                expression = '.history'
            );

            VIZ covid_history USING DUMP;
        </input>
        <expected>
            <statements>
                <statement type="FETCH" name="main.covid_raw">
                    <node type="OBJECT_DASHQL_FETCH" loc="13..105" text="FETCH covi..7_23.json'">
                        <node key="DASHQL_FETCH_FROM_URI" loc="34..105" text="'https://s..7_23.json'" />
                        <node key="DASHQL_STATEMENT_NAME" type="OBJECT_SQL_QUALIFIED_NAME" loc="19..28" text="covid_raw">
                            <node key="SQL_QUALIFIED_NAME_RELATION" loc="19..28" text="covid_raw" />
                        </node>
                    </node>
                </statement>
                <statement type="TRANSFORM" name="main.covid_history">
                    <node type="OBJECT_DASHQL_TRANSFORM" loc="120..229" text="TRANSFORM ..         )">
                        <node key="DASHQL_DATA_SOURCE" type="OBJECT_SQL_QUALIFIED_NAME" loc="130..139" text="covid_raw">
                            <node key="SQL_QUALIFIED_NAME_RELATION" loc="130..139" text="covid_raw" />
                        </node>
                        <node key="DASHQL_STATEMENT_NAME" type="OBJECT_SQL_QUALIFIED_NAME" loc="145..158" text="covid_history">
                            <node key="SQL_QUALIFIED_NAME_RELATION" loc="145..158" text="covid_history" />
                        </node>
                        <node key="DASHQL_TRANSFORM_METHOD" value="JMESPATH" />
                        <node key="DSON_EXPRESSION" loc="205..215" text="'.history'" />
                    </node>
                </statement>
                <statement type="VIZUALIZE">
                    <node type="OBJECT_DASHQL_VIZ" loc="244..272" text="VIZ covid_..USING DUMP">
                        <node key="DASHQL_VIZ_COMPONENTS">
                            <node type="OBJECT_DASHQL_VIZ_COMPONENT" loc="268..272" text="DUMP">
                                <node key="DASHQL_VIZ_COMPONENT_TYPE" value="HEX" />
                            </node>
                        </node>
                        <node key="DASHQL_VIZ_TARGET" type="OBJECT_SQL_TABLE_REF" loc="248..261" text="covid_history">
                            <node key="SQL_TABLE_INHERIT" value="true" />
                            <node key="SQL_TABLE_NAME" type="OBJECT_SQL_QUALIFIED_NAME" loc="248..261" text="covid_history">
                                <node key="SQL_QUALIFIED_NAME_RELATION" loc="248..261" text="covid_history" />
                            </node>
                        </node>
                    </node>
                </statement>
            </statements>
            <errors />
            <line_breaks>
                <line_break loc="0..1" text="&#10;" />
                <line_break loc="106..107" text="&#10;" />
                <line_break loc="107..108" text="&#10;" />
                <line_break loc="175..176" text="&#10;" />
                <line_break loc="215..216" text="&#10;" />
                <line_break loc="230..231" text="&#10;" />
                <line_break loc="231..232" text="&#10;" />
                <line_break loc="273..274" text="&#10;" />
            </line_breaks>
            <comments />
            <dson_keys />
            <dependencies>
                <dependency type="TABLE_REF" source="0" target="1" loc="130..139" text="covid_raw" />
                <dependency type="TABLE_REF" source="1" target="2" loc="248..261" text="covid_history" />
            </dependencies>
        </expected>
    </test>
</tests>
