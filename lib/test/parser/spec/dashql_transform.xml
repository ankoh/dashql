                            <node key="SQL_QUALIFIED_NAME_RELATION" loc="10..16" text="table1" />
                        </node>
                        <node key="DASHQL_STATEMENT_NAME" type="OBJECT_SQL_QUALIFIED_NAME" loc="22..28" text="table2">
                            <node key="SQL_QUALIFIED_NAME_RELATION" loc="22..28" text="table2" />
                        </node>
                        <node key="DASHQL_TRANSFORM_METHOD" value="JMESPATH" />
                    </node>
                </statement>
            </statements>
            <errors />
            <line_breaks />
            <comments />
            <dson_keys />
            <dependencies />
        </expected>
    </test>
