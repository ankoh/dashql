                                <node key="DASHQL_OPTION_ROW" loc="81..82" text="0" />
                                <node key="DASHQL_OPTION_WIDTH" loc="104..105" text="4" />
                            </node>
                            <node key="DASHQL_OPTION_X" type="OBJECT_SQL_COLUMN_REF" loc="137..138" text="a">
                                <node key="SQL_COLUMN_REF_PATH">
                                    <node loc="137..138" text="a" />
                                </node>
                            </node>
                            <node key="DASHQL_OPTION_Y" type="OBJECT_SQL_COLUMN_REF" loc="156..157" text="b">
                                <node key="SQL_COLUMN_REF_PATH">
                                    <node loc="156..157" text="b" />
