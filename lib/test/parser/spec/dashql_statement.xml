    <expected>
        <statements>
            <statement type="VIZUALIZE">
                <node type="OBJECT_DASHQL_VIZ" loc="9..95" text="VIZ weathe..&#10;        )">
                    <node key="DASHQL_VIZ_COMPONENTS">
                        <node type="OBJECT_DASHQL_VIZ_COMPONENT" loc="31..95" text="LINE (&#10;   ..&#10;        )">
