<test name="dashql_syntax_error">
    <input>?</input>
    <expected>
        <statements />
        <errors>
            <error message="syntax error, unexpected '?', expecting EOF" loc="0..1" text="?" />
        </errors>
        <line_breaks />
        <comments />
        <dependencies />
    </expected>
</test>
<test name="load_url_plain">
    <input>
        FETCH weather_csv FROM http (
            url = 'https://localhost/test'
        );
    </input>
    <expected>
        <statements>
            <statement type="FETCH" name="main.weather_csv">
                <node type="OBJECT_DASHQL_FETCH" loc="9..91" text="FETCH weat..&#10;        )">
                    <node key="DASHQL_FETCH_METHOD" value="HTTP" />
                    <node key="DASHQL_STATEMENT_NAME" type="OBJECT_SQL_QUALIFIED_NAME" loc="15..26" text="weather_csv">
                        <node key="SQL_QUALIFIED_NAME_RELATION" loc="15..26" text="weather_csv" />
                    </node>
                    <node key="DASHQL_OPTION_URL" loc="57..81" text="'https://l..host/test'" />
                </node>
            </statement>
        </statements>
        <errors />
        <line_breaks>
            <line_break loc="0..1" text="&#10;" />
            <line_break loc="38..39" text="&#10;" />
            <line_break loc="81..82" text="&#10;" />
            <line_break loc="92..93" text="&#10;" />
        </line_breaks>
        <comments />
        <dependencies />
    </expected>
</test>
<test name="load_url_parameter">
    <input>
        FETCH weather_csv FROM http (
            url = format('https://cdn.dashql.com/demo/weather/%s', main.country)
        );
    </input>
    <expected>
        <statements>
            <statement type="FETCH" name="main.weather_csv">
                <node type="OBJECT_DASHQL_FETCH" loc="9..129" text="FETCH weat..&#10;        )">
                    <node key="DASHQL_FETCH_METHOD" value="HTTP" />
                    <node key="DASHQL_STATEMENT_NAME" type="OBJECT_SQL_QUALIFIED_NAME" loc="15..26" text="weather_csv">
                        <node key="SQL_QUALIFIED_NAME_RELATION" loc="15..26" text="weather_csv" />
                    </node>
                    <node key="DASHQL_OPTION_URL" type="OBJECT_DASHQL_FUNCTION_CALL" loc="57..119" text="format('ht..n.country)">
                        <node key="SQL_FUNCTION_ARGUMENTS">
                            <node loc="64..104" text="'https://c..eather/%s'" />
                            <node type="OBJECT_SQL_COLUMN_REF" loc="106..118" text="main.country">
                                <node key="SQL_COLUMN_REF_PATH">
                                    <node loc="106..110" text="main" />
                                    <node loc="111..118" text="country" />
                                </node>
                            </node>
                        </node>
                        <node key="SQL_FUNCTION_NAME" loc="57..63" text="format" />
                    </node>
                </node>
            </statement>
        </statements>
        <errors />
        <line_breaks>
            <line_break loc="0..1" text="&#10;" />
            <line_break loc="38..39" text="&#10;" />
            <line_break loc="119..120" text="&#10;" />
            <line_break loc="130..131" text="&#10;" />
        </line_breaks>
        <comments />
        <dependencies />
    </expected>
</test>
<test name="dashql_viz_position">
    <input>
        VIZ weather_avg USING LINE (
            position = (
                row = 0,
                column = 0,
                width = 4,
                height = 15
            )
        )
    </input>
    <expected>
        <statements>
            <statement type="VIZUALIZE">
                <node type="OBJECT_DASHQL_VIZ" loc="9..194" text="VIZ weathe..&#10;        )">
                    <node key="DASHQL_VIZ_COMPONENTS">
                        <node type="OBJECT_DASHQL_VIZ_COMPONENT" loc="31..194" text="LINE (&#10;   ..&#10;        )">
                            <node key="DASHQL_VIZ_COMPONENT_TYPE" value="LINE" />
                            <node key="DASHQL_OPTION_POSITION" type="OBJECT_DASHQL_OPTION_LIST" loc="61..184" text="(&#10;        ..         )">
                                <node key="DASHQL_OPTION_ROW" loc="85..86" text="0" />
                                <node key="DASHQL_OPTION_COLUMN" loc="113..114" text="0" />
                                <node key="DASHQL_OPTION_WIDTH" loc="140..141" text="4" />
                                <node key="DASHQL_OPTION_HEIGHT" loc="168..170" text="15" />
                            </node>
                        </node>
                    </node>
                    <node key="DASHQL_VIZ_TARGET" type="OBJECT_SQL_TABLE_REF" loc="13..24" text="weather_avg">
                        <node key="SQL_TABLE_INHERIT" value="true" />
                        <node key="SQL_TABLE_NAME" type="OBJECT_SQL_QUALIFIED_NAME" loc="13..24" text="weather_avg">
                            <node key="SQL_QUALIFIED_NAME_RELATION" loc="13..24" text="weather_avg" />
                        </node>
                    </node>
                </node>
            </statement>
        </statements>
        <errors />
        <line_breaks>
            <line_break loc="0..1" text="&#10;" />
            <line_break loc="37..38" text="&#10;" />
            <line_break loc="62..63" text="&#10;" />
            <line_break loc="87..88" text="&#10;" />
            <line_break loc="115..116" text="&#10;" />
            <line_break loc="142..143" text="&#10;" />
            <line_break loc="170..171" text="&#10;" />
            <line_break loc="184..185" text="&#10;" />
            <line_break loc="194..195" text="&#10;" />
        </line_breaks>
        <comments />
        <dependencies />
    </expected>
</test>
<test name="dashql_viz_position_short">
    <input>
        VIZ weather_avg USING LINE (
            pos = (r = 0, c = 0, w = 4, h = 15)
        )
