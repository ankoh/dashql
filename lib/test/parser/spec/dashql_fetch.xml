<test name="load_uni_zip_http">
    <input>
        FETCH uni FROM http (
            url = 'https://static.dashql.com/data/uni/de/all.zip'
        );
        LOAD assistenten FROM uni['assistenten.parquet'] USING PARQUET;
    </input>
    <expected>
        <statements>
            <statement type="FETCH" name="main.uni">
                <node type="OBJECT_DASHQL_FETCH" loc="9..106" text="FETCH uni ..&#10;        )">
                    <node key="DASHQL_FETCH_METHOD" value="HTTP" />
                    <node key="DASHQL_STATEMENT_NAME" type="OBJECT_SQL_QUALIFIED_NAME" loc="15..18" text="uni">
                        <node key="SQL_QUALIFIED_NAME_RELATION" loc="15..18" text="uni" />
                    </node>
                    <node key="DASHQL_OPTION_URL" loc="49..96" text="'https://s..e/all.zip'" />
