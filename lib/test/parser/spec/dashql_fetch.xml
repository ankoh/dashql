                    </node>
                    <node key="DASHQL_EXTRACT_METHOD" value="PARQUET" />
                    <node key="DASHQL_STATEMENT_NAME" type="OBJECT_SQL_QUALIFIED_NAME" loc="124..135" text="assistenten">
