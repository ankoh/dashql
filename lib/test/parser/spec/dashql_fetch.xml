            </statement>
            <statement type="LOAD" name="main.assistenten">
                <node type="OBJECT_DASHQL_LOAD" loc="116..178" text="LOAD assis..NG PARQUET">
                    <node key="DASHQL_LOAD_DATA" type="OBJECT_SQL_QUALIFIED_NAME" loc="138..164" text="uni['assis...parquet']">
                        <node key="SQL_QUALIFIED_NAME_INDEX" type="OBJECT_SQL_INDIRECTION_INDEX" loc="141..164" text="['assisten...parquet']">
                            <node key="SQL_INDIRECTION_INDEX_VALUE" loc="142..163" text="'assistent..n.parquet'" />
                        </node>
                        <node key="SQL_QUALIFIED_NAME_RELATION" loc="138..141" text="uni" />
                    </node>
                    <node key="DASHQL_LOAD_METHOD" value="PARQUET" />
                    <node key="DASHQL_STATEMENT_NAME" type="OBJECT_SQL_QUALIFIED_NAME" loc="121..132" text="assistenten">
                        <node key="SQL_QUALIFIED_NAME_RELATION" loc="121..132" text="assistenten" />
                    </node>
                </node>
            </statement>
        </statements>
        <errors />
        <line_breaks>
            <line_break loc="0..1" text="&#10;" />
            <line_break loc="30..31" text="&#10;" />
            <line_break loc="96..97" text="&#10;" />
            <line_break loc="107..108" text="&#10;" />
