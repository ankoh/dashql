#!/bin/bash
set -euo pipefail

PROJECT_ROOT="$(cd $(dirname "$BASH_SOURCE[0]") && cd .. && pwd)" &> /dev/null

npx prettier \
    --write "$PROJECT_ROOT/**/*.{js,json,ts,tsx,d.ts,css,scss}" \
    --config "$PROJECT_ROOT/.prettierrc" \
    --ignore-path "$PROJECT_ROOT/.prettierignore"

find -E $PROJECT_ROOT \
    -regex '.*/(\..*|submodules|proto|install|build|node_modules)/.*' -prune -o \
    -regex '.*\.(cc|h)' \
    -exec echo clang-format -i {} \; \
    -exec clang-format -i {} \;
