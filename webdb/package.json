{
    "name": "@dashql/webdb",
    "version": "0.0.10",
    "description": "DuckDB powered by WebAssembly",
    "author": "Andre Kohn <kohn.a@outlook.com>",
    "license": "MPL-2.0",
    "dependencies": {
        "@dashql/proto": "^0.0.3",
        "fast-glob": "^3.2.5",
        "flatbuffers": "^1.12.0"
    },
    "devDependencies": {
        "@types/emscripten": "^1.39.4",
        "@types/flatbuffers": "^1.10.0",
        "@types/jest": "^26.0.20",
        "clean-webpack-plugin": "^3.0.0",
        "compression-webpack-plugin": "^7.1.2",
        "file-loader": "^6.2.0",
        "jasmine-spec-reporter": "^6.0.0",
        "jest": "^26.6.3",
        "jest-junit": "^12.0.0",
        "karma": "^6.2.0",
        "karma-chrome-launcher": "^3.1.0",
        "karma-jasmine": "^4.0.1",
        "karma-webpack": "^5.0.0",
        "puppeteer": "^8.0.0",
        "ts-jest": "^26.5.3",
        "ts-loader": "^8.0.17",
        "ts-node": "^9.1.1",
        "typescript": "^4.2.3",
        "web-worker": "^1.0.0",
        "webpack": "^5.24.4",
        "webpack-cli": "^4.5.0",
        "webpack-node-externals": "^2.5.2"
    },
    "optionalDependencies": {
        "fsevents": "*"
    },
    "scripts": {
        "link": "npm link ../proto",
        "build": "webpack --mode=production && node ./gendts.js",
        "build:noexternals": "webpack -c  --mode=production && node ./gendts.js",
        "test": "jest",
        "test:ci": "jest --ci --reporters=default --reporters=jest-junit",
        "test:karma": "karma start karma.conf.js"
    },
    "files": [
        "dist/**/*.d.ts",
        "dist/**/*.js",
        "dist/*.wasm"
    ],
    "main": "./dist/webdb_node.js",
    "types": "./dist/webdb_node.d.ts",
    "browser": {
        "./dist/webdb_node.js": "./dist/webdb.js",
        "perf_hooks": false,
        "fs": false,
        "buffer": false
    },
    "jest-junit": {
        "suiteName": "Javascript",
        "outputDirectory": "../reports",
        "outputName": "tests_js.xml",
        "uniqueOutputName": "false",
        "classNameTemplate": "{classname}",
        "titleTemplate": "{title}",
        "ancestorSeparator": " › ",
        "usePathForSuiteName": "true"
    }
}
