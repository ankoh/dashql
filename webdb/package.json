{
    "name": "@dashql/webdb",
    "version": "0.0.8",
    "description": "DuckDB powered by WebAssembly",
    "author": "Andre Kohn <kohn.a@outlook.com>",
    "license": "AGPL-3.0-or-later",
    "dependencies": {
        "@dashql/proto": "file:../proto/",
        "flatbuffers": "^1.12.0"
    },
    "devDependencies": {
        "@types/emscripten": "^1.39.4",
        "@types/flatbuffers": "^1.10.0",
        "@types/jest": "^26.0.14",
        "clean-webpack-plugin": "^3.0.0",
        "compression-webpack-plugin": "^7.0.0",
        "file-loader": "^6.1.0",
        "jest": "^26.4.2",
        "jest-junit": "^12.0.0",
        "ts-jest": "^26.4.1",
        "ts-loader": "^8.0.4",
        "typescript": "^4.0.3",
        "web-worker": "^1.0.0",
        "webpack": "^5.1.3",
        "webpack-cli": "^4.1.0",
        "webpack-node-externals": "^2.5.2"
    },
    "optionalDependencies": {
        "fsevents": "*"
    },
    "scripts": {
        "build": "webpack --mode=production && node ./gendts.js",
        "test": "node ./node_modules/jest/bin/jest.js",
        "test:ci": "node ./node_modules/jest/bin/jest.js --ci --reporters=default --reporters=jest-junit"
    },
    "files": [
        "dist/**/*.d.ts",
        "dist/**/*.js",
        "dist/*.wasm"
    ],
    "main": "./dist/webdb_node.js",
    "types": "./dist/webdb_node.d.ts",
    "browser": {
        "./dist/webdb_node.js": "./dist/webdb.js",
        "perf_hooks": false,
        "fs": false,
        "buffer": false
    },
    "jest-junit": {
        "suiteName": "Javascript",
        "outputDirectory": "../reports",
        "outputName": "tests_js.xml",
        "uniqueOutputName": "false",
        "classNameTemplate": "{classname}",
        "titleTemplate": "{title}",
        "ancestorSeparator": " › ",
        "usePathForSuiteName": "true"
    }
}
