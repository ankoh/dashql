include "analyzer.fbs";

namespace dashql.proto.edit;

table VizChangePosition {
    row: uint32;
    column: uint32;
    width: uint32;
    height: uint32;
}

union EditOperationVariant {
    VizChangePosition
}

table EditOperation {
    statement_id: uint32;
    variant: EditOperationVariant;
}

table ProgramEdit {
    edits: [EditOperation];
}
