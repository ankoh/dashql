include "sql_type.fbs";

namespace dashql.proto.sql;

enum PhysicalType: uint8 {
    NULL_,
    U32,
    I64,
    F64,
    STRING
}

table SQLValue {
    logical_type: SQLType;
    physical_type: PhysicalType;
    is_null: bool;
    data_u32: uint32;
    data_i64: int64;
    data_f64: double;
    data_str: string;
}
