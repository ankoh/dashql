include "duckdb/query_plan.fbs";
include "duckdb/sql_type.fbs";
include "duckdb/vector.fbs";

namespace duckdb.web.proto;

// Query arguments
table QueryArguments {
    script: string;
    partition_boundaries: [uint32];
}

// A query result chunk
table QueryResultChunk {
    query_id: uint64;
    row_count: uint32;
    columns: [Vector];
    partition_boundaries: [uint8];
}

// A query result
table QueryResult {
    query_id: uint64;
    query_plan: QueryPlan;
    column_types: [SQLType];
    column_names: [string];
    partitioned_by: [uint32];
    data_chunks: [QueryResultChunk];
}
