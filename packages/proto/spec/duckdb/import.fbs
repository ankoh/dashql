include "duckdb/query_plan.fbs";
include "duckdb/sql_type.fbs";
include "duckdb/vector.fbs";

namespace duckdb.web.proto;

table ImportDataChunk {
    table_id: uint64;
    row_count: uint64;
    columns: [Vector];
}

table ImportTable {
    table_id: uint64;
    table_name: string;
    column_types: [SQLType];
    column_names: [string];
}

table ImportHeader {
    tables: [ImportTable];
}
