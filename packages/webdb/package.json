{
    "name": "@dashql/webdb",
    "version": "0.0.19",
    "description": "DuckDB powered by WebAssembly",
    "author": "Andre Kohn <kohn.a@outlook.com>",
    "license": "MPL-2.0",
    "dependencies": {
        "@dashql/proto": "^0.0.4",
        "glob-to-regexp": "^0.4.1"
    },
    "devDependencies": {
        "@types/emscripten": "^1.39.4",
        "@types/glob-to-regexp": "^0.4.0",
        "@types/jasmine": "^3.6.7",
        "esbuild": "^0.9.6",
        "fs-temp": "^1.2.1",
        "jasmine": "3.7.0",
        "jasmine-spec-reporter": "^6.0.0",
        "karma": "^6.2.0",
        "karma-chrome-launcher": "^3.1.0",
        "karma-coverage": "^2.0.3",
        "karma-firefox-launcher": "^2.1.0",
        "karma-jasmine": "^4.0.1",
        "karma-sourcemap-loader": "^0.3.8",
        "karma-spec-reporter": "^0.0.32",
        "make-dir": "^3.1.0",
        "nyc": "^15.1.0",
        "puppeteer": "^8.0.0",
        "rimraf": "^3.0.2",
        "temp-write": "^4.0.0",
        "typescript": "^4.2.3",
        "web-worker": "^1.0.0"
    },
    "optionalDependencies": {
        "fsevents": "*"
    },
    "scripts": {
        "build": "node bundle.mjs && tsc --emitDeclarationOnly",
        "report": "node ./coverage.mjs",
        "test:node": "jasmine ./dist/tests-node.js",
        "test:node:cov": "nyc -r json --report-dir ./coverage/node jasmine ./dist/tests-node.js",
        "test:browser": "karma start karma.conf.cjs",
        "test:browser:cov": "karma start karma.conf.cov.cjs",
        "test": "npm run test:browser && npm run test:node",
        "test:cov": "npm run test:browser:cov && npm run test:node:cov && npm run report",
        "test:ci": "npm run test:cov"
    },
    "files": [
        "dist/types/**/*.d.ts",
        "dist/chunk*.js",
        "dist/webdb*.js",
        "dist/webdb.wasm"
    ],
    "main": "./dist/webdb-node.js",
    "types": "./dist/webdb-node.d.ts",
    "module": "./dist/webdb.module.js",
    "browser": {
        "./dist/webdb-node.js": "./dist/webdb-browser.js",
        "worker_threads": false,
        "perf_hooks": false,
        "fs": false,
        "buffer": false
    }
}
