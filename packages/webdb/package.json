        "@types/jasmine": "^3.6.7",
        "clean-webpack-plugin": "^3.0.0",
        "compression-webpack-plugin": "^7.1.2",
        "file-loader": "^6.2.0",
        "jasmine": "3.7.0",
        "jasmine-spec-reporter": "^6.0.0",
        "karma": "^6.2.0",
        "karma-chrome-launcher": "^3.1.0",
        "karma-jasmine": "^4.0.1",
        "karma-spec-reporter": "^0.0.32",
        "karma-webpack": "^5.0.0",
        "puppeteer": "^8.0.0",
        "ts-loader": "^8.0.18",
        "ts-node": "^9.1.1",
        "typescript": "^4.2.3",
