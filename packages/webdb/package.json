{
    "name": "@dashql/webdb",
    "version": "0.0.14",
    "description": "DuckDB powered by WebAssembly",
    "author": "Andre Kohn <kohn.a@outlook.com>",
    "license": "MPL-2.0",
    "dependencies": {
        "@dashql/proto": "^0.0.3",
        "fast-glob": "^3.2.5"
    },
    "devDependencies": {
        "@types/emscripten": "^1.39.4",
        "@types/jasmine": "^3.6.7",
        "esbuild": "^0.9.6",
        "jasmine": "3.7.0",
        "jasmine-spec-reporter": "^6.0.0",
        "karma": "^6.2.0",
        "karma-chrome-launcher": "^3.1.0",
        "karma-firefox-launcher": "^2.1.0",
        "karma-jasmine": "^4.0.1",
        "karma-spec-reporter": "^0.0.32",
        "puppeteer": "^8.0.0",
        "source-map-support": "^0.5.19",
        "ts-node": "^9.1.1",
        "typescript": "^4.2.3"
    },
    "optionalDependencies": {
        "fsevents": "*"
    },
    "scripts": {
        "build": "tsc --emitDeclarationOnly && node bundle.mjs",
        "test:node": "NODE_OPTIONS='-r source-map-support/register' jasmine ./dist/tests-node.js",
        "test:browser": "karma start karma.conf.cjs",
        "test": "npm run test:browser && npm run test:node",
        "test:ci": "npm run test:browser && npm run test:node"
    },
    "files": [
        "dist/**/*.d.ts",
        "dist/**/*.js",
        "dist/*.wasm"
    ],
    "main": "./dist/webdb-node-serial.js",
    "types": "./dist/webdb-node-serial.d.ts",
    "module": "./dist/webdb.module.js",
    "browser": {
        "./dist/webdb-node-serial.js": "./dist/webdb-browser-serial.js",
        "worker_threads": false,
        "perf_hooks": false,
        "fs": false,
        "buffer": false
    }
}
