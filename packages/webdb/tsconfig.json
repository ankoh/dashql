{
    "compilerOptions": {
        "outDir": "./dist/",
        "target": "es6",
        "module": "es6",
        "moduleResolution": "node",
        "strict": true,
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "declarationDir": "./dist/types/",
        "noImplicitAny": true,
        "esModuleInterop": true,
        "downlevelIteration": true,
        "types": ["emscripten", "node", "jasmine"],
        "baseUrl": ".",
        "lib": ["es6", "webworker"]
    },
    "include": ["./src/**/*", "./types/*.d.ts", "./test/**/*"]
}
