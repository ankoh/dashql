{
  // dashql-cloud: one Worker bound to two custom domains, routed by hostname.
  //   ai.dashql.app      -> OpenAI-compatible API (/v1/models, /v1/chat/completions)
  //   account.dashql.app -> human login/dashboard (Sign in with Apple, API-key management)
  "name": "dashql-cloud",
  "main": "build/worker/shim.mjs", // generated by workers-rs / worker-build
  "compatibility_date": "2026-01-01",
  "build": {
    "command": "cargo install -q worker-build && worker-build --release"
  },
  // Workers AI binding, accessed from Rust as env.ai("AI").
  "ai": {
    "binding": "AI"
  },
  // KV, one namespace each. Create with `npx wrangler kv namespace create <NAME>` and paste the
  //   printed id below.
  //   DASHQL_CLOUD_API_KEYS      -> hashed API keys + per-key budgets (owner-indexed).
  //   DASHQL_CLOUD_API_KEY_USAGE -> per-window usage counters (keyed by window-start timestamp).
  //   DASHQL_CLOUD_ACCOUNTS      -> allowlist: <lowercased-email> -> { enabled, added_at }. The
  //                                 single source of truth for who may mint a key.
  "kv_namespaces": [
    {
      "binding": "DASHQL_CLOUD_API_KEYS",
      "id": "53e36a989f60404a8c50c93a39720b34"
    },
    {
      "binding": "DASHQL_CLOUD_API_KEY_USAGE",
      "id": "e03464d5f18349229122d13c603deaaf"
    },
    {
      "binding": "DASHQL_CLOUD_ACCOUNTS",
      "id": "ef81131f2de349e2af8c7c98c008a49d"
    }
  ],
  // Both custom domains map to this single Worker (requires dashql.app to be a zone
  // on the same Cloudflare account).
  "routes": [
    {
      "pattern": "ai.dashql.app",
      "custom_domain": true
    },
    {
      "pattern": "account.dashql.app",
      "custom_domain": true
    }
  ],
  "vars": {
    // Apple "Services ID" — this is the OAuth client_id and the JWT `aud` we verify.
    "APPLE_SERVICE_ID": "app.dashql.account",
    // The origin Apple redirects back to (must match the registered return URL).
    "ACCOUNT_ORIGIN": "https://account.dashql.app",
    // (The allowlist is not a var — it lives in the DASHQL_CLOUD_ACCOUNTS KV namespace so it can
    //  be edited without a redeploy. See DEPLOY.md → "Managing the allowlist".)
    // Quota knobs.
    //   REQUEST_LIMIT     — per-key request budget per window. Baked onto each key at creation
    //                       time, so changing it only affects keys minted afterwards.
    //   NEURON_LIMIT      — per-key neuron budget per window (neurons = Cloudflare's GPU-compute
    //                       unit; derived from a request's token counts). Also baked per key.
    //   QUOTA_WINDOW_SECS — reset cadence, deployment-wide and read fresh per request, so
    //                       changing it takes effect on redeploy for ALL keys at once
    //                       (18000 = 5h, like Claude subscriptions).
    "REQUEST_LIMIT": "500",
    "NEURON_LIMIT": "10000",
    "QUOTA_WINDOW_SECS": "18000"
  }
  // Secret (set via `npx wrangler secret put SESSION_SECRET`): HMAC key for session cookies.
}
