load("@aspect_bazel_lib//lib:copy_to_directory.bzl", "copy_to_directory")
load("@rules_rust//cargo:defs.bzl", "cargo_build_script")
load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_test")
load("//bazel:macos_packaging.bzl", "codesign", "hdiutil", "lipo", "platform_binary")
load("//packages/tauri-aclgen:tauri_acl.bzl", "gen_tauri_acl")

exports_files(["Cargo.toml"])

_MACOS_ONLY = ["@platforms//os:macos"]

# ---------------------------------------------------------------------------
# Frontend dependency (Vite-built web app)
# ---------------------------------------------------------------------------

copy_to_directory(
    name = "dep_dashql_app",
    srcs = ["//packages/dashql-app:reloc"],
    out = "./dependencies/dashql-app",
    replace_prefixes = {"packages/dashql-app/reloc": ""},
    visibility = ["//visibility:private"],
)

# ---------------------------------------------------------------------------
# Pre-generate Tauri ACL files from plugin permission TOMLs + capabilities.
# This replaces the sandbox path remapping hacks that were needed when
# tauri_build::try_build() consumed DEP_*_PERMISSION_FILES_PATH env vars.
# ---------------------------------------------------------------------------

gen_tauri_acl(
    name = "tauri_acl",
    core_config = "acl_core_permissions.toml",
    capabilities = ["acl_capabilities.json"],
    plugins = {
        "@crates__tauri-plugin-deep-link-2.4.7//:permission_files": "deep-link",
        "@crates__tauri-plugin-dialog-2.6.0//:permission_files": "dialog",
        "@crates__tauri-plugin-fs-2.4.5//:permission_files": "fs",
        "@crates__tauri-plugin-http-2.5.7//:permission_files": "http",
        "@crates__tauri-plugin-log-2.8.0//:permission_files": "log",
        "@crates__tauri-plugin-os-2.3.2//:permission_files": "os",
        "@crates__tauri-plugin-process-2.3.1//:permission_files": "process",
        "@crates__tauri-plugin-shell-2.3.5//:permission_files": "shell",
        "@crates__tauri-plugin-updater-2.10.0//:permission_files": "updater",
    },
    tool = "//packages/tauri-aclgen:tauri_aclgen",
)

# ---------------------------------------------------------------------------
# Build scripts (proto codegen + Tauri cfg flags)
# ---------------------------------------------------------------------------

_BUILD_SCRIPT_DATA = [
    "Cargo.toml",
    "tauri.conf.json",
    "acl_capabilities.json",
    "@bazel_tools//tools/proto:protoc",
    "//proto/pb:native_proto_srcs",
    "//proto/pb:google/protobuf/empty.proto",
    "//proto/pb:salesforce/hyperdb/grpc/v1/hyper_service.proto",
    "//proto/pb:dashql/test/test_service.proto",
    ":tauri_acl",
]

_BUILD_SCRIPT_DEPS = [
    "@crates//:tauri-build",
    "@crates//:tonic-prost-build",
]

cargo_build_script(
    name = "build_script",
    srcs = ["build.rs"],
    pkg_name = "dashql-native",
    data = _BUILD_SCRIPT_DATA,
    build_script_env = {
        "PROTOC": "$(execpath @bazel_tools//tools/proto:protoc)",
        "PROTO_HYPER_SERVICE": "$(execpath //proto/pb:salesforce/hyperdb/grpc/v1/hyper_service.proto)",
        "PROTO_TEST_SERVICE": "$(execpath //proto/pb:dashql/test/test_service.proto)",
        "DEP_TAURI_DEV": "false",
        "TAURI_ACL_DIR": "$(execpath :tauri_acl)",
    },
    deps = _BUILD_SCRIPT_DEPS,
    rundir = "packages/dashql-native",
)

cargo_build_script(
    name = "build_script_dev",
    srcs = ["build.rs"],
    pkg_name = "dashql-native",
    data = _BUILD_SCRIPT_DATA,
    build_script_env = {
        "PROTOC": "$(execpath @bazel_tools//tools/proto:protoc)",
        "PROTO_HYPER_SERVICE": "$(execpath //proto/pb:salesforce/hyperdb/grpc/v1/hyper_service.proto)",
        "PROTO_TEST_SERVICE": "$(execpath //proto/pb:dashql/test/test_service.proto)",
        "DEP_TAURI_DEV": "true",
        "TAURI_ACL_DIR": "$(execpath :tauri_acl)",
    },
    deps = _BUILD_SCRIPT_DEPS,
    rundir = "packages/dashql-native",
)

# ---------------------------------------------------------------------------
# Icon assets from source-controlled files
# ---------------------------------------------------------------------------

genrule(
    name = "icon_icns",
    srcs = ["//misc/logo-dashql-glyphs:icon_icns_source"],
    outs = ["icon.icns"],
    cmd = "cp $(location //misc/logo-dashql-glyphs:icon_icns_source) $@",
)

genrule(
    name = "icon_png",
    srcs = ["//misc/logo-dashql-glyphs:iconset"],
    outs = ["icon.png"],
    cmd = "for f in $(SRCS); do case \"$$f\" in *512x512*2x*) cp \"$$f\" $@; break;; esac; done",
)

_ICON_SIZES = [
    "16x16", "16x16@2x", "32x32", "32x32@2x",
    "64x64", "64x64@2x", "128x128", "128x128@2x",
    "256x256", "256x256@2x", "512x512", "512x512@2x",
]

copy_to_directory(
    name = "dep_icons",
    srcs = [
        ":icon_icns",
        ":icon_png",
        "//misc/logo-dashql-glyphs:iconset",
    ],
    out = "dep_icons",
    replace_prefixes = {
        "misc/logo-dashql-glyphs/app_icons_mac.iconset/icon_": "",
    },
)

# ---------------------------------------------------------------------------
# Tauri config overrides
# ---------------------------------------------------------------------------

TAURI_CONFIG_ICON_PATHS = (
    ["./dep_icons/icon.icns", "./dep_icons/icon.png"] +
    ["./dep_icons/%s.png" % s for s in _ICON_SIZES]
)

TAURI_CONFIG_OVERRIDE = json.encode({
    "build": {"frontendDist": "./dependencies/dashql-app"},
    "bundle": {"icon": TAURI_CONFIG_ICON_PATHS},
})
TAURI_CONFIG_OVERRIDE_DEV = json.encode({
    "build": {"frontendDist": "./dependencies/dashql-app"},
    "app": {"windows": [{"fullscreen": False, "height": 800, "hiddenTitle": True, "resizable": True, "title": "DashQL (Dev)", "titleBarStyle": "Overlay", "width": 1400, "url": "http://localhost:9002/"}]},
    "bundle": {"icon": TAURI_CONFIG_ICON_PATHS},
})

