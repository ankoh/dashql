# ---------------------------------------------------------------------------
# Rust binary targets
# ---------------------------------------------------------------------------

rust_binary(
    name = "app",
    srcs = glob(["src/**/*.rs"]),
    crate_root = "src/main.rs",
    compile_data = _COMPILE_DATA,
    rustc_env = {"TAURI_CONFIG": TAURI_CONFIG_OVERRIDE},
    deps = [":build_script"] + _SHARED_DEPS,
)

# Dev binary: window URL overridden to http://localhost:9002 so the app loads
# from the Vite dev server instead of embedded assets.  Run in two terminals:
#   bazel run //packages/dashql-app:dev
#   bazel run //packages/dashql-native:dev
rust_binary(
    name = "dev",
    srcs = glob(["src/**/*.rs"]),
    crate_root = "src/main.rs",
    compile_data = _COMPILE_DATA,
    rustc_env = {"TAURI_CONFIG": TAURI_CONFIG_OVERRIDE_DEV},
    deps = [":build_script_dev"] + _SHARED_DEPS,
)

rust_test(
    name = "tests",
    crate = ":app",
    compile_data = _COMPILE_DATA,
    rustc_env = {"TAURI_CONFIG": TAURI_CONFIG_OVERRIDE},
)

# ---------------------------------------------------------------------------
# macOS packaging
# ---------------------------------------------------------------------------

copy_to_directory(
    name = "mac_app_bundle",
    srcs = [":app", "Info.bundle.plist", ":icon_icns"],
    out = "DashQL.app",
    replace_prefixes = {
        "app": "Contents/MacOS/DashQL",
        "Info.bundle.plist": "Contents/Info.plist",
        "icon.icns": "Contents/Resources/icon.icns",
    },
    target_compatible_with = _MACOS_ONLY,
    visibility = ["//visibility:public"],
)

copy_to_directory(
    name = "mac_dmg_src",
    srcs = [":mac_app_bundle"],
    out = "dmg_volume",
    target_compatible_with = _MACOS_ONLY,
)

hdiutil(
    name = "mac_dmg",
    srcfolder = ":mac_dmg_src",
    volname = "DashQL",
    out = "DashQL.dmg",
    target_compatible_with = _MACOS_ONLY,
    visibility = ["//visibility:public"],
)

# Universal binary (aarch64 + x86_64) via lipo.
# Requires: CARGO_BAZEL_REPIN=1 bazel build @crates//:all  (once, after adding x86_64-apple-darwin triple)
platform_binary(
    name = "mac_app_aarch64",
    binary = ":app",
    platform = "//bazel/platforms:aarch64_macos",
    tags = ["manual"],
    target_compatible_with = _MACOS_ONLY,
    visibility = ["//visibility:public"],
)
platform_binary(
    name = "mac_app_x86_64",
    binary = ":app",
    platform = "//bazel/platforms:x86_64_macos",
    tags = ["manual"],
    target_compatible_with = _MACOS_ONLY,
    visibility = ["//visibility:public"],
)
lipo(
    name = "mac_universal_app",
    inputs = [":mac_app_aarch64", ":mac_app_x86_64"],
    out = "DashQL-universal",
    tags = ["manual"],
    target_compatible_with = _MACOS_ONLY,
    visibility = ["//visibility:public"],
)

copy_to_directory(
    name = "mac_universal_app_bundle",
    srcs = [":mac_universal_app", "Info.bundle.plist", ":icon_icns"],
    out = "DashQL-universal.app",
    replace_prefixes = {
        "DashQL-universal": "Contents/MacOS/DashQL",
        "Info.bundle.plist": "Contents/Info.plist",
        "icon.icns": "Contents/Resources/icon.icns",
    },
    tags = ["manual"],
    target_compatible_with = _MACOS_ONLY,
    visibility = ["//visibility:public"],
)

copy_to_directory(
    name = "mac_universal_dmg_src",
    srcs = [":mac_universal_app_bundle"],
    out = "universal_dmg_volume",
    replace_prefixes = {"DashQL-universal.app": "DashQL.app"},
    tags = ["manual"],
    target_compatible_with = _MACOS_ONLY,
)
hdiutil(
    name = "mac_universal_dmg",
    srcfolder = ":mac_universal_dmg_src",
    volname = "DashQL",
    out = "DashQL-universal.dmg",
    tags = ["manual"],
    target_compatible_with = _MACOS_ONLY,
    visibility = ["//visibility:public"],
)

# Updater tar.gz
#
# Tauri's install_inner does: entry.path().iter().skip(1).collect()
# i.e. strips the first path component, extracts the rest into a temp dir,
# then renames that temp dir to the current .app path.  The archive must
# therefore have exactly ONE component before Contents/, e.g.:
#   DashQL.app/Contents/MacOS/DashQL
# Using the aspect_bazel_lib tar rule produces paths like:
#   packages/dashql-native/DashQL.app/Contents/...
# which corrupts the install.
genrule(
    name = "mac_updater_bundle",
    srcs = [":mac_app_bundle"],
    outs = ["DashQL.app.tar.gz"],
    cmd = "tar -chzf $@ -C $$(dirname $(location :mac_app_bundle)) $$(basename $(location :mac_app_bundle))",
    tags = ["manual"],
    target_compatible_with = _MACOS_ONLY,
    visibility = ["//visibility:public"],
)

genrule(
    name = "mac_universal_updater_bundle",
    srcs = [":mac_universal_app_bundle"],
    outs = ["DashQL-universal.app.tar.gz"],
    cmd = "tar -chzf $@ -C $$(dirname $(location :mac_universal_app_bundle)) $$(basename $(location :mac_universal_app_bundle))",
    tags = ["manual"],
    target_compatible_with = _MACOS_ONLY,
    visibility = ["//visibility:public"],
)

# ---------------------------------------------------------------------------
# Signed universal packaging (requires APPLE_SIGNING_IDENTITY in env)
# ---------------------------------------------------------------------------

codesign(
    name = "mac_universal_app_bundle_signed",
    app = ":mac_universal_app_bundle",
    entitlements = "Entitlements.plist",
    out = "DashQL-universal-signed.app",
    tags = ["manual"],
    target_compatible_with = _MACOS_ONLY,
    visibility = ["//visibility:public"],
)

copy_to_directory(
    name = "mac_universal_dmg_signed_src",
    srcs = [":mac_universal_app_bundle_signed"],
    out = "mac_universal_dmg_signed_src",
    replace_prefixes = {"DashQL-universal-signed.app": "DashQL.app"},
    tags = ["manual"],
    target_compatible_with = _MACOS_ONLY,
)

hdiutil(
    name = "mac_universal_dmg_signed",
    srcfolder = ":mac_universal_dmg_signed_src",
    volname = "DashQL",
    out = "DashQL-universal-signed.dmg",
    tags = ["manual"],
    target_compatible_with = _MACOS_ONLY,
    visibility = ["//visibility:public"],
)

genrule(
    name = "mac_universal_updater_bundle_signed",
    srcs = [":mac_universal_app_bundle_signed"],
    outs = ["DashQL-universal-signed.app.tar.gz"],
    cmd = "tar -chzf $@ -C $$(dirname $(location :mac_universal_app_bundle_signed)) $$(basename $(location :mac_universal_app_bundle_signed))",
    tags = ["manual"],
    target_compatible_with = _MACOS_ONLY,
    visibility = ["//visibility:public"],
)
