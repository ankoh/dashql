{
    "$schema": "https://schema.tauri.app/config/2",
    "app": {
        "security": {
            "csp": null,
            "headers": {
                "Cross-Origin-Opener-Policy": "same-origin",
                "Cross-Origin-Embedder-Policy": "require-corp"
            }
        },
        "windows": [
            {
                "fullscreen": false,
                "height": 800,
                "hiddenTitle": true,
                "resizable": true,
                "title": "DashQL",
                "titleBarStyle": "Overlay",
                "width": 1400
            }
        ],
        "withGlobalTauri": false
    },
    "identifier": "app.dashql",
    "plugins": {
        "updater": {
            "active": true,
            "dialog": true,
            "endpoints": [
                "https://get.dashql.app/update"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJEQ0Y5MDE5Nzc1OEIwRUEKUldUcXNGaDNHWkRQTGUwVnV0LzlzWnNGWnNWL0tKWkhDOEFvclNSNERPSlRJUldTMEV1Q2FVd1gK"
        },
        "deep-link": {
            "mobile": [
                {
                    "host": "localhost"
                },
                {
                    "host": "dashql.app"
                }
            ],
            "desktop": {
                "schemes": [
                    "dashql"
                ]
            }
        }
    },
    "productName": "DashQL",
    "version": "0.0.2-dev.17"
}
