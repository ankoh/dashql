# Protobuf TS gen + dist. Gen: protoc + protoc-gen-es (TypeScript). Dist: tsc + esbuild.
package(default_visibility = ["//visibility:public"])

load("//packages/dashql-protobuf:dist.bzl", "dashql_protobuf_dist")

exports_files([
    "package.json",
    "index.ts",
    "bundle.ts",
    "tsconfig.json",
    "scripts/build_bazel.cjs",
])

dashql_protobuf_dist(name = "dist", gen = "//proto/pb:ts_gen")
