{
    "compilerOptions": {
        "outDir": "./dist/",
        "target": "es2017",
        "module": "esnext",
        "moduleResolution": "node",
        "strict": true,
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "declarationDir": "./dist/types",
        "noImplicitAny": true,
        "esModuleInterop": true,
        "types": ["node"],
        "baseUrl": ".",
        "lib": ["webworker"]
    },
    "include": ["./src/**/*", "./types/*.d.ts"]
}
