{
    "name": "@dashql/dataframe",
    "version": "0.0.8",
    "description": "A Dataframe powered by WebAssembly",
    "license": "AGPL-3.0-or-later",
    "dependencies": {
        "@dashql/proto": "^0.0.3",
        "flatbuffers": "^1.12.0",
        "fsevents": "*"
    },
    "devDependencies": {
        "@types/emscripten": "^1.39.4",
        "@types/flatbuffers": "^1.10.0",
        "@types/jest": "^26.0.21",
        "clean-webpack-plugin": "^3.0.0",
        "compression-webpack-plugin": "^7.1.2",
        "file-loader": "^6.2.0",
        "jest": "^26.6.3",
        "jest-junit": "^12.0.0",
        "ts-jest": "^26.5.4",
        "ts-loader": "^8.0.18",
        "typescript": "^4.2.3",
        "web-worker": "^1.0.0",
        "webpack": "^5.27.1",
        "webpack-cli": "^4.5.0",
        "webpack-node-externals": "^2.5.2"
    },
    "optionalDependencies": {
        "fsevents": "*"
    },
    "scripts": {
        "build": "webpack --mode=production && node ./gendts.js",
        "test": "jest",
        "test:ci": "jest --ci --reporters=default --reporters=jest-junit"
    },
    "files": [
        "dist/**/*.d.ts",
        "dist/**/*.js",
        "dist/*.wasm"
    ],
    "main": "./dist/dataframe_node.js",
    "types": "./dist/dataframe_node.d.ts",
    "browser": {
        "./dist/dataframe_node.js": "./dist/dataframe.js",
        "perf_hooks": false,
        "fs": false,
        "buffer": false
    },
    "jest-junit": {
        "suiteName": "Javascript",
        "outputDirectory": "../reports",
        "outputName": "tests_js.xml",
        "uniqueOutputName": "false",
        "classNameTemplate": "{classname}",
        "titleTemplate": "{title}",
        "ancestorSeparator": " › ",
        "usePathForSuiteName": "true"
    }
}
