# utf8proc - in-tree vendor (used by dashql for Unicode).

load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "utf8proc",
    srcs = [
        "utf8proc.cpp",
        "utf8proc_wrapper.cpp",
    ],
    hdrs = glob(["include/**/*.hpp"]) + ["utf8proc.data"],
    includes = ["include", "."],
)
