# dashql-core: C++ library and native tests (Bazel).
# Grammar, version, parser/scanner generation, main library.

load("@rules_cc//cc:defs.bzl", "cc_library", "cc_binary", "cc_test")

package(default_visibility = ["//visibility:public"])

# macOS 13.3+ required for std::format (uses std::to_chars for floating point).
config_setting(
    name = "macos",
    constraint_values = ["@platforms//os:macos"],
)

# ---------------------------------------------------------------------------
# Version (git describe -> version.cc via repository_rule in bazel/version.bzl)
# ---------------------------------------------------------------------------

cc_library(
    name = "dashql_version",
    srcs = ["@dashql_core_version//:version.cc"],
    hdrs = ["include/dashql/version.h"],
    includes = ["include"],
)

# ---------------------------------------------------------------------------
# Main library (dashql)
# ---------------------------------------------------------------------------
LIB_SRCS = [
    "src/analyzer/analysis_state.cc",
    "src/analyzer/analyzer.cc",
    "src/analyzer/completion.cc",
    "src/analyzer/constant_propagation_pass.cc",
    "src/analyzer/identify_column_filters_pass.cc",
    "src/analyzer/identify_column_computations_pass.cc",
    "src/analyzer/identify_function_calls_pass.cc",
    "src/analyzer/name_resolution_pass.cc",
    "src/analyzer/pass_manager.cc",
    "src/api.cc",
    "src/catalog.cc",
    "src/formatter/formatter.cc",
    "src/formatter/formatting_buffer.cc",
    "src/parser/grammar/enums.cc",
    "src/parser/grammar/keywords.cc",
    "src/parser/grammar/state.cc",
    "src/parser/grammar/tokens.cc",
    "src/parser/parse_context.cc",
    "src/parser/parser.cc",
    "src/parser/scanner.cc",
    "src/script.cc",
    "src/script_comparison.cc",
    "src/script_cursor.cc",
    "src/script_registry.cc",
    "src/script_signature.cc",
    "src/script_snippet.cc",
    "src/text/names.cc",
    "src/utils/murmur3.cc",
    "src/utils/rope.cc",
    "src/utils/string_conversion.cc",
    "src/view/hyper_plan_parser.cc",
    "src/view/plan_view_model.cc",
    "src/view/plan_layout.cc",
]

DASHQL_COPTS = select({
    ":macos": [
        "-std=c++20",
        "-mmacosx-version-min=13.3",  # std::format / std::to_chars for long double
        "-DFLATBUFFERS_NO_ABSOLUTE_PATH_RESOLUTION",
    ],
    "//conditions:default": [
        "-std=c++20",
        "-DFLATBUFFERS_NO_ABSOLUTE_PATH_RESOLUTION",
    ],
})
DASHQL_LINKOPTS = select({
    ":macos": ["-std=c++20", "-mmacosx-version-min=13.3"],
    "//conditions:default": ["-std=c++20"],
})

cc_library(
    name = "dashql",
    srcs = LIB_SRCS + [
        "//grammar:parser_generated",
        "//grammar:scanner_generated",
    ],
    hdrs = glob(
        ["include/**/*.h"],
        # Now generated by bazel, remove once cmake is gone
        exclude = ["include/dashql/buffers/*.h"],
    ),
    includes = ["include"],
    copts = DASHQL_COPTS,
    linkopts = DASHQL_LINKOPTS,
    deps = [
        "//grammar:grammar_lists_include",
        "//grammar:parser_generated_headers",
        "//packages/dashql-core/vendor/frozen:frozen",
        "//packages/dashql-core/vendor/utf8proc:utf8proc",
        "//proto/fb:dashql_buffers_cc",
        ":dashql_version",
        "@ankerl_unordered_dense//:ankerl",
        "@com_google_flatbuffers//:flatbuffers",
        "@rapidjson//:rapidjson",
    ],
)

# ---------------------------------------------------------------------------
# Test utils and tester (snapshot tests use rapidyaml)
# ---------------------------------------------------------------------------

TESTUTILS_SRCS = [
    "src/testing/analyzer_snapshot_test.cc",
    "src/testing/completion_snapshot_test.cc",
    "src/testing/formatter_snapshot_test.cc",
    "src/testing/parser_snapshot_test.cc",
    "src/testing/plan_view_model_snapshot_test.cc",
    "src/testing/registry_snapshot_test.cc",
    "src/testing/yaml_tests.cc",
]

cc_library(
    name = "dashql_testutils",
    srcs = TESTUTILS_SRCS,
    hdrs = glob(["include/dashql/testing/*.h"]),
    includes = ["include"],
    copts = DASHQL_COPTS,
    linkopts = DASHQL_LINKOPTS,
    deps = [
        ":dashql",
        "@googletest//:gtest",
        "@rapidyaml//:rapidyaml",
    ],
)

# Test sources for tester binary. Exclude catalog_test until duckdb is in the extension.
TEST_SRCS = [
    "test/analyzer_snapshot_test_suite.cc",
    "test/api_test.cc",
    "test/chunk_buffer_test.cc",
    "test/completion_snapshot_test_suite.cc",
    "test/completion_test.cc",
    "test/cursor_test.cc",
    "test/formatter_snapshot_test_suite.cc",
    "test/keywords_test.cc",
    "test/name_tagging_test.cc",
    "test/parser_snapshot_test_suite.cc",
    "test/parser_test.cc",
    "test/plan_view_model_snapshot_test_suite.cc",
    "test/plan_view_model_test.cc",
    "test/pmh_unordered_map.cc",
    "test/registry_snapshot_test_suite.cc",
    "test/rope_test.cc",
    "test/scanner_test.cc",
    "test/script_test.cc",
    "test/topk_test.cc",
    "test/unification_test.cc",
    "test/catalog_test.cc",
]

cc_binary(
    name = "tester",
    srcs = ["test/tester.cc", "test/runfiles_dir.cc"] + TEST_SRCS,
    data = ["//snapshots:snapshot_tests"],
    copts = DASHQL_COPTS,
    linkopts = DASHQL_LINKOPTS,
    deps = [
        ":dashql_testutils",
        "@googletest//:gtest",
        "@gflags//:gflags",
    ],
)
