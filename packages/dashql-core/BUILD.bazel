DASHQL_COPTS = [
    "-std=c++20",
    "-DFLATBUFFERS_NO_ABSOLUTE_PATH_RESOLUTION",
    "-Wno-deprecated-declarations",
]
DASHQL_LINKOPTS = ["-std=c++20"]

# Header-only library shared by dashql_core (native) and dashql_core_wasm.
# exclude include/dashql/buffers/*.h: generated by bazel, remove once cmake is gone
cc_library(
    name = "dashql_core_headers",
    hdrs = glob(
        ["include/**/*.h"],
        exclude = ["include/dashql/buffers/*.h"],
    ),
    includes = ["include"],
)

# Shared deps for native dashql_core and WASM build (parser_generated_wasm, dashql_core_wasm).
CORE_DEPS = [
    "//grammar:grammar_lists_include",
    "//grammar:parser_generated_headers",
    "//packages/dashql-core/vendor/frozen:frozen",
    "//packages/dashql-core/vendor/utf8proc:utf8proc",
    "//proto/fb:dashql_buffers_cc",
    ":dashql_core_headers",
    "@ankerl_unordered_dense//:ankerl",
    "@com_google_flatbuffers//:flatbuffers",
    "@rapidjson//:rapidjson",
]

cc_library(
    name = "dashql_core",
    srcs = LIB_SRCS + [
        "//grammar:parser_generated",
        "//grammar:scanner_generated",
    ],
    copts = DASHQL_COPTS,
    linkopts = DASHQL_LINKOPTS,
    deps = CORE_DEPS + [":version"],
)

# ---------------------------------------------------------------------------
# WASM binary (build with: bazel build //packages/dashql-core:core_wasm)
# ---------------------------------------------------------------------------

# Bison-generated parser is compiled with -O1 only (see :parser_generated_wasm) to avoid
# "local count too large" in V8/Node; rest stays unoptimized (CMake: set_source_files_properties(parser_generated.cc COMPILE_OPTIONS "-O1")).

WASM_COPTS = [
    "-std=c++20",
    "-DWASM=1",
    "-DFLATBUFFERS_NO_ABSOLUTE_PATH_RESOLUTION",
    "-Wno-deprecated-declarations",
    "-mbulk-memory",
]
WASM_LINKOPTS = [
    # Enable ES6 module output for modern bundlers
    "-sMODULARIZE=1",
    "-sEXPORT_ES6=1",
    "-sEXPORT_NAME=createDashQLModule",

    # Export all C functions (note: underscore prefix required in JS)
    "-sEXPORTED_FUNCTIONS=[" +
        "'_dashql_version'," +
        "'_dashql_malloc'," +
        "'_dashql_free'," +
        "'_dashql_delete_owner'," +
        "'_dashql_catalog_new'," +
        "'_dashql_catalog_clear'," +
        "'_dashql_catalog_contains_entry_id'," +
        "'_dashql_catalog_describe_entries'," +
        "'_dashql_catalog_describe_entries_of'," +
        "'_dashql_catalog_load_script'," +
        "'_dashql_catalog_drop_script'," +
        "'_dashql_catalog_add_descriptor_pool'," +
        "'_dashql_catalog_drop_descriptor_pool'," +
        "'_dashql_catalog_add_schema_descriptor'," +
        "'_dashql_catalog_add_schema_descriptors'," +
        "'_dashql_catalog_get_statistics'," +
        "'_dashql_catalog_flatten'," +
        "'_dashql_script_new'," +
        "'_dashql_script_get_catalog_entry_id'," +
        "'_dashql_script_insert_text_at'," +
        "'_dashql_script_insert_char_at'," +
        "'_dashql_script_erase_text_range'," +
        "'_dashql_script_replace_text'," +
        "'_dashql_script_to_string'," +
        "'_dashql_script_scan'," +
        "'_dashql_script_parse'," +
        "'_dashql_script_analyze'," +
        "'_dashql_script_get_scanned'," +
        "'_dashql_script_get_parsed'," +
        "'_dashql_script_get_analyzed'," +
        "'_dashql_script_get_statistics'," +
        "'_dashql_script_move_cursor'," +
        "'_dashql_script_complete_at_cursor'," +
        "'_dashql_script_select_completion_candidate_at_cursor'," +
        "'_dashql_script_select_completion_catalog_object_at_cursor'," +
        "'_dashql_script_registry_new'," +
        "'_dashql_script_registry_clear'," +
        "'_dashql_script_registry_add_script'," +
        "'_dashql_script_registry_drop_script'," +
        "'_dashql_script_registry_find_column'," +
        "'_dashql_plan_view_model_configure'," +
        "'_dashql_plan_view_model_load_hyper_plan'," +
        "'_dashql_plan_view_model_new'," +
        "'_dashql_plan_view_model_pack'," +
        "'_dashql_plan_view_model_reset'," +
        "'_dashql_plan_view_model_reset_execution'" +
    "]",

    # Export runtime helper functions and heap views
    "-sEXPORTED_RUNTIME_METHODS=['ccall','cwrap','stackSave','stackAlloc','stackRestore','HEAP8','HEAP16','HEAP32','HEAPU8','HEAPU16','HEAPU32','HEAP64','HEAPU64','HEAPF32','HEAPF64']",

    # Enable memory growth for dynamic allocation
    "-sALLOW_MEMORY_GROWTH=1",

    # Disable standalone WASM mode to enable JS glue
    "-sSTANDALONE_WASM=0",

    # Control initial memory (16MB default)
    "-sINITIAL_MEMORY=16777216",

    # Size optimizations
    "-sAGGRESSIVE_VARIABLE_ELIMINATION=1",
    "-sELIMINATE_DUPLICATE_FUNCTIONS=1",
    "-sFILESYSTEM=0",
    "-sENVIRONMENT='web,node'",
    "-sUSE_WEBGL2=0",
    "-sUSE_SDL=0",
]

# Parser generated .cc compiled with -O1 only (bison output has huge local count at -O0).
cc_library(
    name = "parser_generated_wasm",
    srcs = ["//grammar:gen/include/dashql/parser/parser_generated.cc"],
    copts = WASM_COPTS + ["-O1"],
    features = ["wasm_exceptions", "wasm_simd"],
    target_compatible_with = ["@platforms//cpu:wasm32"],
    deps = CORE_DEPS,
)

# Inline version.cc directly so it is compiled with the emscripten toolchain.
cc_binary(
    name = "dashql_core_wasm",
    srcs = LIB_SRCS + [
        "@dashql_core_version//:version.cc",
        "//grammar:scanner_generated",
    ],
    copts = WASM_COPTS,
    features = ["wasm_exceptions", "wasm_simd"],
    linkopts = WASM_LINKOPTS,
    tags = ["manual"],
    target_compatible_with = ["@platforms//cpu:wasm32"],
    deps = [":parser_generated_wasm"] + CORE_DEPS,
)

wasm_cc_binary(
    name = "core_wasm",
    cc_target = ":dashql_core_wasm",
    standalone = False,
    outputs = [
        "dashql_core.wasm",
        "dashql_core.js",
    ],
    tags = ["manual"],
    visibility = ["//visibility:public"],
)

