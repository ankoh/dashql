    "src/analyzer/analyzer.cc",
    "src/analyzer/completion.cc",
    "src/analyzer/constant_propagation_pass.cc",
    "src/analyzer/identify_column_filters_pass.cc",
    "src/analyzer/identify_column_computations_pass.cc",
    "src/analyzer/identify_function_calls_pass.cc",
    "src/analyzer/name_resolution_pass.cc",
    "src/analyzer/pass_manager.cc",
    "src/api.cc",
    "src/catalog.cc",
    "src/formatter/formatter.cc",
    "src/formatter/formatting_buffer.cc",
    "src/parser/grammar/enums.cc",
    "src/parser/grammar/keywords.cc",
    "src/parser/grammar/state.cc",
    "src/parser/grammar/tokens.cc",
    "src/parser/parse_context.cc",
    "src/parser/parser.cc",
    "src/parser/scanner.cc",
    "src/script.cc",
    "src/script_comparison.cc",
    "src/script_cursor.cc",
    "src/script_registry.cc",
    "src/script_signature.cc",
    "src/script_snippet.cc",
    "src/text/names.cc",
    "src/utils/murmur3.cc",
    "src/utils/rope.cc",
    "src/utils/string_conversion.cc",
    "src/view/hyper_plan_parser.cc",
    "src/view/plan_view_model.cc",
    "src/view/plan_layout.cc",
]

DASHQL_COPTS = select({
    ":macos": [
        "-std=c++20",
        "-mmacosx-version-min=13.3",  # std::format / std::to_chars for long double
        "-DFLATBUFFERS_NO_ABSOLUTE_PATH_RESOLUTION",
    ],
    "//conditions:default": [
        "-std=c++20",
        "-DFLATBUFFERS_NO_ABSOLUTE_PATH_RESOLUTION",
    ],
})
DASHQL_LINKOPTS = select({
    ":macos": ["-std=c++20", "-mmacosx-version-min=13.3"],
    "//conditions:default": ["-std=c++20"],
})

cc_library(
    name = "dashql",
    srcs = LIB_SRCS + [
        ":scanner_generated",
        ":parser_generated",
    ],
    hdrs = glob(["include/**/*.h"]),
    includes = ["include"],
    copts = DASHQL_COPTS,
    linkopts = DASHQL_LINKOPTS,
    deps = [
        ":grammar_lists_include",
        ":dashql_version",
        "@com_google_flatbuffers//:flatbuffers",
        "@ankerl_unordered_dense//:ankerl",
        "@rapidjson//:rapidjson",
        "//packages/dashql-core/vendor/utf8proc:utf8proc",
        "//packages/dashql-core/vendor/frozen:frozen",
    ],
)

