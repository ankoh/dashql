# Header-only library shared by dashql_core (native) and dashql_core_wasm.
# exclude include/dashql/buffers/*.h: generated by bazel, remove once cmake is gone
cc_library(
    name = "dashql_core_headers",
    hdrs = glob(
        ["include/**/*.h"],
        exclude = ["include/dashql/buffers/*.h"],
    ),
    includes = ["include"],
)

# Shared deps for native dashql_core and WASM build (parser_generated_wasm, dashql_core_wasm).
CORE_DEPS = [
    "//grammar:grammar_lists_include",
    "//grammar:parser_generated_headers",
    "//packages/dashql-core/vendor/frozen:frozen",
    "//packages/dashql-core/vendor/utf8proc:utf8proc",
    "//proto/fb:dashql_buffers_cc",
    ":dashql_core_headers",
    "@ankerl_unordered_dense//:ankerl",
    "@com_google_flatbuffers//:flatbuffers",
    "@rapidjson//:rapidjson",
]

cc_library(
    name = "dashql_core",
    srcs = LIB_SRCS + [
        "//grammar:parser_generated",
        "//grammar:scanner_generated",
    ],
    copts = DASHQL_COPTS,
    linkopts = DASHQL_LINKOPTS,
    deps = CORE_DEPS + [":dashql_version"],
)

# ---------------------------------------------------------------------------
# WASM binary (build with: bazel build --platforms=//bazel/platforms:wasm32
#   //packages/dashql-core:dashql_core_wasm or //packages/dashql-core:dashql_core_wasm_opt)
# ---------------------------------------------------------------------------

# Bison-generated parser is compiled with -O1 only (see :parser_generated_wasm) to avoid
# "local count too large" in V8/Node; rest stays unoptimized (CMake: set_source_files_properties(parser_generated.cc COMPILE_OPTIONS "-O1")).

WASM_COPTS = [
    "-std=c++20",
    "-DWASM=1",
    "--target=wasm32-wasi",
    "-fno-exceptions",
    "-DFLATBUFFERS_NO_ABSOLUTE_PATH_RESOLUTION",
]
WASM_LINKOPTS = [
    "-flto",
    "-Wl,--export=dashql_version",
    "-Wl,--export=dashql_malloc",
    "-Wl,--export=dashql_free",
    "-Wl,--export=dashql_delete_result",
    "-Wl,--export=dashql_catalog_new",
    "-Wl,--export=dashql_catalog_clear",
    "-Wl,--export=dashql_catalog_contains_entry_id",
    "-Wl,--export=dashql_catalog_describe_entries",
    "-Wl,--export=dashql_catalog_describe_entries_of",
    "-Wl,--export=dashql_catalog_load_script",
    "-Wl,--export=dashql_catalog_drop_script",
    "-Wl,--export=dashql_catalog_add_descriptor_pool",
    "-Wl,--export=dashql_catalog_drop_descriptor_pool",
    "-Wl,--export=dashql_catalog_add_schema_descriptor",
    "-Wl,--export=dashql_catalog_add_schema_descriptors",
    "-Wl,--export=dashql_catalog_get_statistics",
    "-Wl,--export=dashql_catalog_flatten",
    "-Wl,--export=dashql_script_new",
    "-Wl,--export=dashql_script_insert_text_at",
    "-Wl,--export=dashql_script_insert_char_at",
    "-Wl,--export=dashql_script_erase_text_range",
    "-Wl,--export=dashql_script_replace_text",
    "-Wl,--export=dashql_script_to_string",
    "-Wl,--export=dashql_script_scan",
    "-Wl,--export=dashql_script_parse",
    "-Wl,--export=dashql_script_analyze",
    "-Wl,--export=dashql_script_get_catalog_entry_id",
    "-Wl,--export=dashql_script_get_scanned",
    "-Wl,--export=dashql_script_get_parsed",
    "-Wl,--export=dashql_script_get_analyzed",
    "-Wl,--export=dashql_script_get_statistics",
    "-Wl,--export=dashql_script_move_cursor",
    "-Wl,--export=dashql_script_complete_at_cursor",
    "-Wl,--export=dashql_script_select_completion_candidate_at_cursor",
    "-Wl,--export=dashql_script_select_completion_catalog_object_at_cursor",
    "-Wl,--export=dashql_script_registry_new",
    "-Wl,--export=dashql_script_registry_clear",
    "-Wl,--export=dashql_script_registry_add_script",
    "-Wl,--export=dashql_script_registry_drop_script",
    "-Wl,--export=dashql_script_registry_find_column",
    "-Wl,--export=dashql_plan_view_model_configure",
    "-Wl,--export=dashql_plan_view_model_load_hyper_plan",
    "-Wl,--export=dashql_plan_view_model_new",
    "-Wl,--export=dashql_plan_view_model_pack",
    "-Wl,--export=dashql_plan_view_model_reset",
    "-Wl,--export=dashql_plan_view_model_reset_execution",
]

# Parser generated .cc compiled with -O1 only (bison output has huge local count at -O0).
cc_library(
    name = "parser_generated_wasm",
    srcs = ["//grammar:gen/include/dashql/parser/parser_generated.cc"],
    copts = WASM_COPTS + ["-O1"],
    target_compatible_with = ["@platforms//cpu:wasm32"],
    deps = CORE_DEPS,
)

# Inline version.cc into the wasm binary so it is compiled with the WASI toolchain
# (including --sysroot). Using :dashql_version here would build that cc_library for
# wasm32 and some compile actions were not getting the sysroot.
cc_binary(
    name = "dashql_core_wasm_raw",
    srcs = LIB_SRCS + [
        "@dashql_core_version//:version.cc",
        "//grammar:scanner_generated",
    ],
    copts = WASM_COPTS,
    linkopts = WASM_LINKOPTS,
    target_compatible_with = ["@platforms//cpu:wasm32"],
    deps = [":parser_generated_wasm"] + CORE_DEPS,
)

# Copy cc_binary output (dashql_core_wasm.wasm) to dashql_core.wasm so consumers get a uniform name.
# Uses a distinct output name to avoid conflicting with dashql_core_wasm_opt's outs = ["dashql_core.wasm"].
genrule(
    name = "dashql_core_wasm",
    srcs = [":dashql_core_wasm_raw"],
    outs = ["dashql_core.wasm"],
    cmd = "cp $(location :dashql_core_wasm_raw) $@",
    target_compatible_with = ["@platforms//cpu:wasm32"],
)

# Optimized WASM: dashql_core_wasm built with -c opt, then wasm-opt -O3 + wasm_strip.
dashql_core_wasm_opt_raw(
    name = "_dashql_core_wasm_opt_raw",
    wasm = ":dashql_core_wasm_raw",
)
genrule(
    name = "dashql_core_wasm_opt",
    srcs = [":_dashql_core_wasm_opt_raw"],
    outs = ["dashql_core_opt.wasm"],
    cmd = (
        "$(location @binaryen//:wasm_opt) -O3 -o $@ $(location :_dashql_core_wasm_opt_raw) && " +
        "$(location @wabt//:wasm_strip) $@"
    ),
    tools = [
        "@binaryen//:wasm_opt",
        "@wabt//:wasm_strip",
    ],
    target_compatible_with = ["@platforms//cpu:wasm32"],
)

# Wrappers so dependents get wasm32 platform transition when building WASM (no transition in api).
use_wasm32_platform(
    name = "core_wasm",
    dist = ":dashql_core_wasm",
)
use_wasm32_platform(
    name = "core_wasm_opt",
    dist = ":dashql_core_wasm_opt",
)

