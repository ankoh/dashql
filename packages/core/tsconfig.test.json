{
    "compilerOptions": {
        "outDir": "./dist/",
        "target": "es6",
        "module": "commonjs",
        "moduleResolution": "node",
        "sourceMap": true,
        "strict": true,
        "declaration": true,
        "declarationMap": true,
        "declarationDir": "./dist/types/",
        "noImplicitAny": true,
        "esModuleInterop": true,
        "jsx": "react",
        "types": ["emscripten", "node", "jasmine"],
        "lib": ["esnext", "es2020", "dom"],
        "baseUrl": ".",
        "allowJs": true
    },
    "include": ["./src/**/*", "./test/**/*", "./types/*.d.ts"]
}
