{
    "name": "@dashql/core",
    "version": "0.0.2",
    "description": "DashQL Core Library",
    "license": "MPL-2.0",
    "dependencies": {
        "@dashql/duckdb": "^0.0.33",
        "@dashql/proto": "^0.0.5",
        "apache-arrow": "^4.0.1",
        "axios": "^0.21.1",
        "flatbuffers": "^2.0.3",
        "immutable": "^4.0.0-rc.12",
        "redux": "^4.1.0",
        "vega": "^5.20.2",
        "vega-lite": "^5.1.0"
    },
    "devDependencies": {
        "@types/jasmine": "^3.8.1",
        "@types/react": ">=17.0.13",
        "@typescript-eslint/eslint-plugin": "^4.28.2",
        "@typescript-eslint/parser": "^4.28.2",
        "axios-mock-adapter": "^1.19.0",
        "esbuild": "^0.12.15",
        "eslint": "^7.30.0",
        "eslint-config-prettier": "^8.3.0",
        "eslint-plugin-jasmine": "^4.1.2",
        "eslint-plugin-react": "^7.24.0",
        "jasmine": "3.8.0",
        "jasmine-core": "^3.8.0",
        "karma": "^6.3.4",
        "karma-chrome-launcher": "^3.1.0",
        "karma-coverage": "^2.0.3",
        "karma-firefox-launcher": "^2.1.1",
        "karma-jasmine": "^4.0.1",
        "karma-jasmine-html-reporter": "^1.6.0",
        "karma-sourcemap-loader": "^0.3.8",
        "karma-spec-reporter": "^0.0.32",
        "make-dir": "^3.1.0",
        "nyc": "^15.1.0",
        "prettier": "^2.3.2",
        "puppeteer": "^10.1.0",
        "react": "^17.0.2",
        "react-dom": "^17.0.2",
        "rimraf": "^3.0.2",
        "typescript": "^4.3.5"
    },
    "optionalDependencies": {
        "fsevents": "*"
    },
    "scripts": {
        "build": "node bundle.mjs && tsc --emitDeclarationOnly",
        "report": "node ./coverage.mjs",
        "test": "karma start karma.conf.cjs",
        "test:cov": "karma start karma.conf.cov.cjs && npm run report",
        "test:dbg": "karma start karma.conf.dbg.cjs",
        "test:report": "karma start karma.conf.html.cjs --reporters html",
        "test:ci": "npm run test:cov",
        "lint": "yarn run eslint {src,test}/**/*.t{s,sx}"
    },
    "files": [
        "dist/types/**/*.d.ts",
        "dist/chunk*.js",
        "dist/dashql-*.js",
        "dist/dashql-*.wasm"
    ],
    "module": "./dist/dashql-core.module.js",
    "types": "./dist/dashql-core.module.d.ts",
    "browser": {
        "worker_threads": false,
        "perf_hooks": false,
        "fs": false,
        "path": false,
        "buffer": false
    }
}
