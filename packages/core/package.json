{
    "name": "@dashql/core",
    "version": "0.0.2",
    "description": "DashQL Core Library",
    "license": "MPL-2.0",
    "dependencies": {
        "@dashql/proto": "^0.0.3",
        "@dashql/webdb": "^0.0.16",
        "axios": "^0.21.1",
        "hash-wasm": "^4.5.0",
        "immutable": "^4.0.0-rc.12",
        "redux": "^4.0.5",
        "vega": "^5.20.0",
        "vega-lite": "^5.0.0"
    },
    "devDependencies": {
        "@types/react": ">=16.8.0",
        "axios-mock-adapter": "^1.19.0",
        "esbuild": "^0.9.6",
        "karma": "^6.2.0",
        "karma-chrome-launcher": "^3.1.0",
        "karma-coverage": "^2.0.3",
        "karma-firefox-launcher": "^2.1.0",
        "karma-jasmine": "^4.0.1",
        "karma-sourcemap-loader": "^0.3.8",
        "karma-spec-reporter": "^0.0.32",
        "make-dir": "^3.1.0",
        "nyc": "^15.1.0",
        "puppeteer": "^8.0.0",
        "react": "^17.0.1",
        "react-dom": "^17.0.1",
        "rimraf": "^3.0.2",
        "typescript": "^4.2.3"
    },
    "peerDependencies": {
        "@types/react": "^17.0.3",
        "react": "^17.0.1",
        "react-dom": "^17.0.1"
    },
    "optionalDependencies": {
        "fsevents": "*"
    },
    "scripts": {
        "build": "node bundle.mjs && tsc --emitDeclarationOnly",
        "report": "node ./coverage.mjs",
        "test": "karma start karma.conf.cjs",
        "test:cov": "karma start karma.conf.cov.cjs && npm run report",
        "test:ci": "npm run test:cov"
    },
    "files": [
        "dist/**/*.d.ts",
        "dist/**/*.js",
        "dist/*.wasm"
    ],
    "module": "./dist/dashql-core.module.js",
    "types": "./dist/dashql-core.module.d.ts",
    "browser": {
        "worker_threads": false,
        "perf_hooks": false,
        "fs": false,
        "buffer": false
    }
}
