{
    "name": "@dashql/core",
    "version": "0.0.2",
    "description": "DashQL Core Library",
    "license": "MPL-2.0",
    "dependencies": {
        "@dashql/duckdb": "^0.0.23",
        "@dashql/proto": "^0.0.5",
        "apache-arrow": "^3.0.0",
        "axios": "^0.21.1",
        "hash-wasm": "^4.6.0",
        "immutable": "^4.0.0-rc.12",
        "redux": "^4.0.5",
        "vega": "^5.20.2",
        "vega-lite": "^5.0.0"
    },
    "devDependencies": {
        "@types/react": ">=16.8.0",
        "@typescript-eslint/eslint-plugin": "^4.22.0",
        "@typescript-eslint/parser": "^4.22.0",
        "axios-mock-adapter": "^1.19.0",
        "esbuild": "^0.11.10",
        "eslint": "^7.24.0",
        "eslint-config-prettier": "^8.2.0",
        "eslint-plugin-jasmine": "^4.1.2",
        "karma": "^6.3.2",
        "karma-chrome-launcher": "^3.1.0",
        "karma-coverage": "^2.0.3",
        "karma-firefox-launcher": "^2.1.0",
        "karma-jasmine": "^4.0.1",
        "karma-sourcemap-loader": "^0.3.8",
        "karma-spec-reporter": "^0.0.32",
        "make-dir": "^3.1.0",
        "nyc": "^15.1.0",
        "prettier": "^2.2.1",
        "puppeteer": "^8.0.0",
        "react": "^17.0.2",
        "react-dom": "^17.0.2",
        "rimraf": "^3.0.2",
        "typescript": "^4.2.4"
    },
    "peerDependencies": {
        "@types/react": "^17.0.3",
        "react": "^17.0.2",
        "react-dom": "^17.0.2"
    },
    "optionalDependencies": {
        "fsevents": "*"
    },
    "scripts": {
        "build": "node bundle.mjs && tsc --emitDeclarationOnly",
        "report": "node ./coverage.mjs",
        "test": "karma start karma.conf.cjs",
        "test:cov": "karma start karma.conf.cov.cjs && npm run report",
        "test:ci": "npm run test:cov",
        "lint": "eslint {src,test}/**/*.ts"
    },
    "files": [
        "dist/types/**/*.d.ts",
        "dist/chunk*.js",
        "dist/dashql-*.js",
        "dist/dashql-*.wasm"
    ],
    "module": "./dist/dashql-core.module.js",
    "types": "./dist/dashql-core.module.d.ts",
    "browser": {
        "worker_threads": false,
        "perf_hooks": false,
        "fs": false,
        "buffer": false
    }
}
