{
    "name": "@dashql/core",
    "version": "0.0.0",
    "license": "MPL-2.0",
    "private": true,
    "scripts": {
        "start": "webpack serve --config webpack.app.debug.js",
        "build:libs": "node bundle-libs.js && tsc --emitDeclarationOnly",
        "build:app:debug": "webpack --config webpack.app.debug.js",
        "build:app:release": "webpack --config webpack.app.release.js",
        "report": "node ./coverage.js",
        "test:node": "node --enable-source-maps ../../node_modules/jasmine/bin/jasmine ./build/libs/tests-node.cjs",
        "test:node:cov": "nyc -r json --report-dir ./coverage/node node ../../node_modules/jasmine/bin/jasmine ./build/libs/tests-node.cjs",
        "test:browser": "karma start karma.conf.cjs",
        "test:browser:cov": "karma start karma.conf.cov.cjs",
        "test:browser:debug": "karma start karma.conf.dbg.cjs",
        "test": "npm run test:browser && npm run test:node",
        "test:cov": "npm run test:browser:cov && npm run test:node:cov",
        "test:ci": "npm run test:cov && npm run report",
        "analyze:app:debug": "webpack --config webpack.app.debug.js --analyze",
        "analyze:app:release": "webpack --config webpack.app.release.js --analyze",
        "serve:release": "node ./server.js",
        "lint": "yarn run eslint {src,test}/**/*.t{s,sx}"
    },
    "engines": {
        "node": ">=14.13"
    },
    "dependencies": {
        "@dashql/duckdb": "^0.0.36",
        "@dashql/proto": "^0.0.5",
        "@popperjs/core": "^2.9.2",
        "apache-arrow": "^4.0.1",
        "axios": "^0.21.1",
        "bootstrap": "^5.0.2",
        "classnames": "^2.3.1",
        "flatbuffers": "^2.0.3",
        "framer-motion": "^4.1.17",
        "history": "^5.0.0",
        "immutable": "^4.0.0-rc.12",
        "monaco-editor": "^0.25.2",
        "monaco-editor-webpack-plugin": "^4.1.1",
        "rc-scrollbars": "^1.1.3",
        "react": "^17.0.2",
        "react-avatar": "^3.10.0",
        "react-bootstrap": "^1.6.1",
        "react-dom": "^17.0.2",
        "react-grid-layout": "^1.2.5",
        "react-json-tree": "^0.15.0",
        "react-resizable": "^3.0.4",
        "react-router-dom": "^6.0.0-beta.0",
        "react-vega": "^7.4.3",
        "react-virtualized": "^9.22.3",
        "vega": "^5.20.2",
        "vega-lite": "^5.1.0",
        "xterm": "^4.13.0",
        "xterm-addon-fit": "^0.5.0"
    },
    "devDependencies": {
        "@types/classnames": "^2.3.1",
        "@types/d3": "^7.0.0",
        "@types/emscripten": "^1.39.5",
        "@types/flatbuffers": "^1.10.0",
        "@types/jasmine": "^3.8.1",
        "@types/node": "^16.6.1",
        "@types/react-custom-scrollbars": "^4.0.7",
        "@types/react-dom": "^17.0.8",
        "@types/react-grid-layout": "^1.1.1",
        "@types/react-router-dom": "^5.1.8",
        "@types/react-virtualized": "^9.21.11",
        "@typescript-eslint/eslint-plugin": "^4.28.2",
        "@typescript-eslint/parser": "^4.28.2",
        "axios-mock-adapter": "^1.19.0",
        "clean-webpack-plugin": "^3.0.0",
        "copy-webpack-plugin": "^9.0.1",
        "css-loader": "^6.2.0",
        "esbuild": "^0.12.20",
        "eslint": "^7.31.0",
        "eslint-config-prettier": "^8.3.0",
        "eslint-plugin-jasmine": "^4.1.2",
        "eslint-plugin-react": "^7.24.0",
        "eslint-plugin-prettier": "^3.3.1",
        "file-loader": "^6.2.0",
        "html-webpack-plugin": "^5.3.2",
        "jasmine": "3.8.0",
        "jasmine-core": "^3.8.0",
        "jasmine-spec-reporter": "^7.0.0",
        "karma": "^6.3.4",
        "karma-chrome-launcher": "^3.1.0",
        "karma-coverage": "^2.0.3",
        "karma-firefox-launcher": "^2.1.1",
        "karma-jasmine": "^4.0.1",
        "karma-jasmine-html-reporter": "^1.6.0",
        "karma-sourcemap-loader": "^0.3.8",
        "karma-spec-reporter": "^0.0.32",
        "karma-webpack": "^5.0.0",
        "kleur": "^4.1.4",
        "mini-css-extract-plugin": "^2.1.0",
        "nyc": "^15.1.0",
        "prettier": "^2.3.2",
        "prop-types": "^15.7.2",
        "puppeteer": "^10.1.0",
        "source-map-loader": "^3.0.0",
        "style-loader": "^3.0.0",
        "ts-loader": "^9.2.5",
        "typescript": "^4.3.5",
        "typescript-plugin-css-modules": "^3.3.0",
        "webpack": "^5.45.1",
        "webpack-bundle-analyzer": "^4.4.2",
        "webpack-cli": "^4.7.0",
        "webpack-dev-server": "^3.11.2",
        "webpackbar": "^5.0.0-3",
        "web-worker": "^1.0.0"
    },
    "optionalDependencies": {
        "fsevents": "*"
    },
    "browser": {
        "worker_threads": false,
        "perf_hooks": false,
        "fs": false,
        "path": false,
        "buffer": false
    },
    "type": "module"
}
