{
    "name": "@dashql/core",
    "version": "0.0.1",
    "description": "DashQL Core Library",
    "license": "MPL-2.0",
    "dependencies": {
        "@dashql/dataframe": "^0.0.8",
        "@dashql/proto": "^0.0.3",
        "@dashql/webdb": "^0.0.10",
        "axios": "^0.21.1",
        "canvas": "^2.7.0",
        "flatbuffers": "^1.12.0",
        "hash-wasm": "^4.5.0",
        "immutable": "^4.0.0-rc.12",
        "redux": "^4.0.5",
        "vega": "^5.19.1",
        "vega-lite": "^5.0.0"
    },
    "devDependencies": {
        "@types/emscripten": "^1.39.4",
        "@types/flatbuffers": "^1.10.0",
        "@types/jest": "^26.0.20",
        "@types/react": ">=16.8.0",
        "axios-mock-adapter": "^1.19.0",
        "clean-webpack-plugin": "^3.0.0",
        "file-loader": "^6.2.0",
        "jest": "^26.6.3",
        "jest-junit": "^12.0.0",
        "react": "^16.8.0",
        "react-dom": "^16.8.0",
        "ts-jest": "^26.5.3",
        "ts-loader": "^8.0.17",
        "ts-mockito": "^2.6.1",
        "typescript": "^4.2.3",
        "web-worker": "^1.0.0",
        "webpack": "^5.24.4",
        "webpack-cli": "^4.5.0",
        "webpack-node-externals": "^2.5.2",
        "webpackbar": "^5.0.0-3"
    },
    "peerDependencies": {
        "@types/react": "^16.8.0",
        "react": "^16.8.0",
        "react-dom": "^16.8.0"
    },
    "optionalDependencies": {
        "fsevents": "*"
    },
    "scripts": {
        "build:watch": "webpack --watch --progress --mode=production",
        "build": "webpack --mode=production && node ./gendts.js",
        "test": "node ./node_modules/.bin/jest",
        "test:debug": "node --inspect ./node_modules/.bin/jest",
        "test:silent": "node ./node_modules/.bin/jest --silent",
        "test:ci": "node ./node_modules/.bin/jest --ci --reporters=default --reporters=jest-junit"
    },
    "files": [
        "dist/**/*.d.ts",
        "dist/**/*.js",
        "dist/*.wasm"
    ],
    "main": "./dist/dashql_core_node.js",
    "module": "./dist/dashql_core_node.js",
    "types": "./dist/types/src/index_node.d.ts",
    "browser": {
        "./dist/dashql_core_node.js": "./dist/dashql_core.js",
        "worker_threads": false,
        "perf_hooks": false,
        "fs": false,
        "buffer": false
    },
    "jest-junit": {
        "suiteName": "Javascript",
        "outputDirectory": "../reports",
        "outputName": "tests_core.xml",
        "uniqueOutputName": "false",
        "classNameTemplate": "{classname}",
        "titleTemplate": "{title}",
        "ancestorSeparator": " › ",
        "usePathForSuiteName": "true"
    }
}
